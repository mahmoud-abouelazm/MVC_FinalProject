@page
@model Library.Web.Areas.Identity.Pages.Manage.EditProfileModel
@{
}

<div class="max-w-lg mx-auto mt-10 bg-white p-6 rounded-xl shadow">

    <h2 class="text-xl font-bold mb-4">Edit Profile</h2>

    <form method="post"  class="space-y-4">
        @Html.AntiForgeryToken()
        <div>
            <label class="block text-sm font-medium">Full Name</label>
            <input asp-for="Input.FullName"
                   class="w-full border rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" />
            <span asp-validation-for="Input.FullName" class="text-error font-body text-sm"></span>
        </div>

        <div>
            <label class="block text-sm font-medium">Phone</label>
            <input asp-for="Input.PhoneNumber"
                   class="w-full border rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" />
            <span asp-validation-for="Input.PhoneNumber" class="text-error font-body text-sm"></span>
        </div>

        <input type="submit"
                class="w-full bg-blue-600 text-white py-2 rounded hover:bg-blue-700"
                value="Save Changes"   />

    </form>

</div>