@page
@using Library.Web.Core.Constants
@model Library.Web.Areas.Identity.Pages.Manage.ProfileModel
@{
}


<main class="pt-3 sm:pt-8 md:pt-12 pb-12 sm:pb-16 px-4 sm:px-8 md:px-12 max-w-7xl mx-auto flex flex-col md:flex-row gap-6 sm:gap-8 md:gap-12">
    <!-- User Profile Sidebar (Asymmetric Layout) -->
    <aside class="w-full md:w-1/3 flex flex-col gap-6 sm:gap-8">
        <div class="bg-surface-container-lowest p-6 sm:p-8 rounded-xl shadow-[0px_12px_32px_rgba(26,28,26,0.04)] border border-outline-variant/15">
            <div class="flex flex-col items-center text-center">
                <div class="w-24 sm:w-28 md:w-32 h-24 sm:h-28 md:h-32 rounded-full mb-4 sm:mb-6 overflow-hidden ring-4 ring-primary-fixed-dim">
                    <img alt="User Profile" class="w-full h-full object-cover" data-alt="Close-up portrait of a thoughtful man in a library setting with soft natural window lighting and books in background" src="//lh3.googleusercontent.com/aida-public/AB6AXuD5v-8dO4aUpE3_ycLaOmU2AetKHERRJW6ffeKdSqaYSxyiB7qu0ZUVWsJBzKJfzmdb7NRU8fpVkL1naFJcNO1GpCTMYdZ9eJSg7bo2vNG1ZHjM37RYmcaWhE85syG-B_CxxKAttRC1Z9pG64gh_MVoOrA0xw8CKeFKr0ERNKeXanF1sSl5UeCzl1AXfD9bZjG-JuuEP22Qqiobz5gioJyR_fseFc9JPaWDOXvT1dMSzqYZDpZLVDrvpisSi6P1zsnBK9jwaQIx_CMX" />
                </div>
                <h2 class="font-headline text-xl sm:text-2xl md:text-2xl font-bold text-on-surface">@Model.Name</h2>
                @* <p class="font-label text-sm uppercase tracking-widest text-on-surface-variant mb-6">Archival Contributor</p> *@
                <div class="w-full text-left space-y-3 sm:space-y-4 pt-4 sm:pt-6 border-t border-outline-variant/15">
                    <div>
                        <label class="font-label text-[0.6875rem] uppercase tracking-[0.05em] text-on-surface-variant">Email Address</label>
                        <p class="font-body font-semibold text-primary break-all">@Model.Email</p>
                    </div>
                   
                    <div>
                        <label class="font-label text-[0.6875rem] uppercase tracking-[0.05em] text-on-surface-variant">Phone Number</label>
                        <p class="font-body font-semibold">@Model.PhoneNumber</p>
                    </div>
                </div>
            </div>
        </div>
        <!-- Profile Actions -->
        <div class="flex flex-col gap-2 sm:gap-3">
            <a asp-page="/Manage/EditProfile"  class="w-full py-2 sm:py-3 px-4 sm:px-6 bg-primary text-on-primary rounded-md font-manrope font-bold text-xs sm:text-sm flex items-center justify-center gap-2 hover:bg-primary-container transition-all">
                <span class="material-symbols-outlined text-sm" data-icon="edit">edit</span>
                <span class="hidden sm:inline">Edit Profile</span>
                <span class="sm:hidden">Edit</span>
            </a>
            <button class="w-full py-2 sm:py-3 px-4 sm:px-6 bg-surface-container-high text-on-surface rounded-md font-manrope font-bold text-xs sm:text-sm flex items-center justify-center gap-2 hover:bg-surface-variant transition-all">
                <span class="material-symbols-outlined text-sm" data-icon="settings">settings</span>
                <span class="hidden sm:inline">Account Settings</span>
                <span class="sm:hidden">Settings</span>
            </button>
        </div>
    </aside>
    <!-- Rentals Section -->
    <section class="w-full md:w-2/3">
        <div class="mb-6 sm:mb-8 md:mb-10">
            <h1 class="font-headline text-2xl sm:text-3xl md:text-3xl font-bold mb-2">My Collection Circulation</h1>
            <p class="text-sm sm:text-base text-on-surface-variant max-w-xl">Manage your active rentals and archival history. Items highlighted in red require immediate attention or return.</p>
        </div>
        <!-- Active Rentals Bento Grid style summary -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4 mb-8 sm:mb-10">
            <div class="p-4 sm:p-6 bg-primary-fixed-dim/20 rounded-xl border border-primary-fixed-dim/30 flex flex-col justify-between min-h-32 sm:h-40">
                <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl" data-icon="auto_stories">auto_stories</span>
                <div>
                    <p class="text-2xl sm:text-4xl font-bold text-primary">@Model.NumOfActiveRentals</p>
                    <p class="font-label text-[0.6875rem] uppercase tracking-widest text-on-primary-fixed-variant">Active Rentals</p>
                </div>
            </div>
            <div class="p-4 sm:p-6 bg-error-container/30 rounded-xl border border-error-container/50 flex flex-col justify-between min-h-32 sm:h-40">
                <span class="material-symbols-outlined text-error text-2xl sm:text-3xl" data-icon="warning">warning</span>
                <div>
                    <p class="text-2xl sm:text-4xl font-bold text-error">@Model.NumOfOverDueRentals</p>
                    <p class="font-label text-[0.6875rem] uppercase tracking-widest text-on-error-container">Overdue Collection</p>
                </div>
            </div>
        </div>
        <!-- Data Table Section -->
        @* Returned Books Table *@

        @if(Model.ReturnedRentals.Any()){
        <div class="mb-6 sm:mb-8">
            <h3 class="font-headline text-lg sm:text-xl font-bold mb-3 sm:mb-4 text-on-surface">Returned Items</h3>
            <div class="space-y-4 sm:space-y-5">
                @for (int i = 0; i < Model.ReturnedRentals?.Count(); i++)
                {
                    var rental = Model.ReturnedRentals[i];
                    var returnedAt = rental.ReturnedAt ?? DateTime.UtcNow;
                    var daysRented = (int)Math.Floor((returnedAt - rental.RentedAt).TotalDays) + 1;
                    var totalPricePerDay = rental.CopyRentals.Sum(cr => cr.Copy?.Book?.Price ?? 0);
                    var isLate = returnedAt > rental.DueAt;
                    var daysLate = isLate ? (int)Math.Floor((returnedAt - rental.DueAt).TotalDays) : 0;
                    var onTimeDays = Math.Max(0, daysRented - daysLate);
                    var baseAmount = onTimeDays * totalPricePerDay;
                    var numberOfBooks = rental.CopyRentals.Count;
                    var lateFeesPerDay = 5m * numberOfBooks;
                    var penaltyAmount = isLate ? daysLate * lateFeesPerDay : 0;
                    var totalAmount = rental.Amount > 0 ? rental.Amount : baseAmount + penaltyAmount;
                    var copyNames = string.Join(", ", rental.CopyRentals.Select(cr => cr.Copy?.Name).Where(n => !string.IsNullOrWhiteSpace(n)));
                    var bookTitles = string.Join(", ", rental.CopyRentals.Select(cr => cr.Copy?.Book?.Title).Where(t => !string.IsNullOrWhiteSpace(t)).Distinct());
                    var firstBookId = rental.CopyRentals.FirstOrDefault()?.Copy?.Book?.Id;

                    <details class="rounded-xl border border-outline-variant/20 bg-surface-container-lowest shadow-sm overflow-hidden">
                        <summary class="cursor-pointer list-none px-4 sm:px-6 py-4 bg-tertiary text-on-tertiary">
                            <div class="flex items-center justify-between gap-3">
                                <div class="min-w-0">
                                    <p class="font-manrope text-[0.6875rem] uppercase tracking-[0.12em] font-bold opacity-70 mb-1">Rental #@rental.Id</p>
                                    <p class="font-noto-serif text-sm sm:text-lg font-bold truncate">@bookTitles</p>
                                    <p class="font-manrope text-xs opacity-80 mt-0.5">Returned @returnedAt.ToString("MMM d, yyyy")</p>
                                </div>
                                <div class="text-right shrink-0">
                                    <p class="font-manrope text-[0.6875rem] uppercase tracking-[0.12em] font-bold opacity-70">Total Paid</p>
                                    <p class="font-noto-serif text-lg sm:text-2xl font-bold">$@totalAmount.ToString("0.00")</p>
                                </div>
                            </div>
                        </summary>

                        <div class="px-4 sm:px-6 py-4 sm:py-6 space-y-4 sm:space-y-5">
                            <div>
                                <p class="font-manrope text-[0.6875rem] uppercase tracking-[0.1em] font-bold text-on-surface-variant mb-3">Rental Details</p>
                                <div class="space-y-2">
                                    <div class="flex items-start justify-between gap-3 py-2 border-b border-dashed border-outline-variant/30">
                                        <span class="font-manrope text-xs text-on-surface-variant">Book(s)</span>
                                        <span class="font-manrope text-sm font-bold text-on-surface text-right">@bookTitles</span>
                                    </div>
                                    <div class="flex items-start justify-between gap-3 py-2 border-b border-dashed border-outline-variant/30">
                                        <span class="font-manrope text-xs text-on-surface-variant">Copy(s)</span>
                                        <span class="font-manrope text-sm font-bold text-on-surface text-right">@copyNames</span>
                                    </div>
                                    <div class="flex items-start justify-between gap-3 py-2 border-b border-dashed border-outline-variant/30">
                                        <span class="font-manrope text-xs text-on-surface-variant">Rented on</span>
                                        <span class="font-manrope text-sm font-bold text-on-surface">@rental.RentedAt.ToString("MMM d, yyyy")</span>
                                    </div>
                                    <div class="flex items-start justify-between gap-3 py-2 border-b border-dashed border-outline-variant/30">
                                        <span class="font-manrope text-xs text-on-surface-variant">Due date</span>
                                        <span class="font-manrope text-sm font-bold @(isLate ? "text-error" : "text-on-surface")">
                                            @rental.DueAt.ToString("MMM d, yyyy")
                                            @if (isLate)
                                            {
                                                <span class="font-manrope text-xs font-bold text-error ml-2">(overdue)</span>
                                            }
                                        </span>
                                    </div>
                                    <div class="flex items-start justify-between gap-3 py-2">
                                        <span class="font-manrope text-xs text-on-surface-variant">Return date</span>
                                        <span class="font-manrope text-sm font-bold text-on-surface">@returnedAt.ToString("MMM d, yyyy")</span>
                                    </div>
                                </div>
                            </div>

                            <div>
                                <p class="font-manrope text-[0.6875rem] uppercase tracking-[0.1em] font-bold text-on-surface-variant mb-3">Amount Breakdown</p>

                                <div class="flex items-start justify-between gap-3 py-2 border-b border-dashed border-outline-variant/30">
                                    <span class="font-manrope text-xs text-on-surface-variant">
                                        @onTimeDays day@(onTimeDays == 1 ? "" : "s") on time × $@totalPricePerDay.ToString("0.00")
                                    </span>
                                    <span class="font-manrope text-sm font-bold text-on-surface">$@baseAmount.ToString("0.00")</span>
                                </div>

                                @if (isLate)
                                {
                                    <div class="mt-3 p-3 rounded-lg bg-error-container/30 border border-error-container/50 flex items-start justify-between gap-3">
                                        <span class="font-manrope text-xs text-error">
                                            @daysLate day@(daysLate == 1 ? "" : "s") late × $@lateFeesPerDay.ToString("0.00")
                                        </span>
                                        <span class="font-manrope text-sm font-bold text-error">+$@penaltyAmount.ToString("0.00")</span>
                                    </div>
                                }

                                <div class="mt-4 pt-3 border-t-2 border-on-surface flex items-center justify-between gap-3">
                                    <span class="font-noto-serif text-base sm:text-xl font-bold text-on-surface">Total Paid</span>
                                    <span class="font-noto-serif text-xl sm:text-2xl font-bold text-primary">$@totalAmount.ToString("0.00")</span>
                                </div>
                            </div>

                            <a asp-controller="Books" asp-action="Details" asp-route-id="@firstBookId"
                               class="inline-flex w-full items-center justify-center px-4 py-2.5 bg-transparent border border-outline-variant text-on-surface-variant rounded-md font-manrope font-bold text-xs sm:text-sm hover:bg-surface-container-highest transition-all">
                                Re-Rent
                            </a>
                        </div>
                    </details>
                }
            </div>
        </div>
        }


        @* Active Books Table *@      
          
        @if (Model.ActiveRentals.Any())
        {
            <div class="mb-6 sm:mb-8">
                <h3 class="font-headline text-lg sm:text-xl font-bold mb-3 sm:mb-4 text-on-surface">Active Rentals</h3>
                <div class="overflow-x-auto rounded-xl bg-surface-container-low shadow-sm">
                    <table class="w-full text-left border-collapse min-w-max sm:min-w-full">
                        <thead class="bg-tertiary text-on-tertiary sticky top-0">
                            <tr>
                                <th class="px-3 sm:px-6 py-3 sm:py-4 font-label text-[0.6875rem] uppercase tracking-wider whitespace-nowrap">Catalogue Title</th>
                                <th class="px-3 sm:px-6 py-3 sm:py-4 font-label text-[0.6875rem] uppercase tracking-wider whitespace-nowrap">Status</th>
                                <th class="px-3 sm:px-6 py-3 sm:py-4 font-label text-[0.6875rem] uppercase tracking-wider whitespace-nowrap">Copies</th>
                                <th class="px-3 sm:px-6 py-3 sm:py-4 font-label text-[0.6875rem] uppercase tracking-wider whitespace-nowrap">Due At</th>
                                <th class="px-3 sm:px-6 py-3 sm:py-4 font-label text-[0.6875rem] uppercase tracking-wider whitespace-nowrap text-right">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-outline-variant/15">

                            @for (int i = 0; i < Model.ActiveRentals.Count(); i++)
                            {
                                <tr class="bg-surface hover:bg-surface-container-high transition-colors">
                                    <td class="px-3 sm:px-6 py-3 sm:py-5 whitespace-nowrap">
                                        <div class="flex items-center gap-2 sm:gap-4">
                                            <div class="w-8 h-12 sm:w-10 sm:h-14 bg-surface-variant rounded-sm flex-shrink-0 grayscale">
                                                <img alt="Book Cover" class="w-full h-full object-cover rounded-sm" data-alt="@Model.ActiveRentals[i]?.CopyRentals?.FirstOrDefault()?.Copy.Book.Description" src="@Model.ActiveRentals[i]?.CopyRentals?.FirstOrDefault()?.Copy.Book.Img" />
                                            </div>
                                            <div class="min-w-0">
                                                <p class="font-headline text-xs sm:text-base font-bold leading-tight truncate">@Model.ActiveRentals[i]?.CopyRentals?.FirstOrDefault()?.Copy.Book.Title</p>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-3 sm:px-6 py-3 sm:py-5 whitespace-nowrap">
                                        <div class="inline-flex items-center px-2 sm:px-2.5 py-1 sm:py-0.5 rounded-full text-[0.65rem] sm:text-xs font-semibold
                                            @(Model.ActiveRentals[i].DueAt >= DateTime.UtcNow ? "bg-secondary-container text-on-secondary-container" : "bg-error-container text-on-error-container")">
                                            @(Model.ActiveRentals[i].DueAt >= DateTime.UtcNow ? "Active" : "Overdue")
                                        </div>
                                    </td>
                                    <td class="px-3 sm:px-6 py-3 sm:py-5 whitespace-nowrap">
                                        <span class="font-body text-xs sm:text-sm text-on-surface-variant">@Model.ActiveRentals[i].CopyRentals.Count()                                        
                                        </span>
                                    </td>
                                    <td class="px-3 sm:px-6 py-3 sm:py-5 whitespace-nowrap">
                                        <span class="font-body text-xs sm:text-sm @(Model.ActiveRentals[i].DueAt >= DateTime.UtcNow ? "font-semibold" : "font-bold text-error")">
                                            @Model.ActiveRentals[i]?.CopyRentals?.FirstOrDefault()?.Rental.DueAt.ToString("M/d/yyyy")
                                        </span>
                                    </td>
                                    <td class="px-3 sm:px-6 py-3 sm:py-5 whitespace-nowrap text-right">
                                        <a asp-controller="Books" asp-action="Details" asp-route-id="@Model.ActiveRentals[i]?.CopyRentals?.FirstOrDefault()?.Copy.Book.Id"
                                               class="inline-block px-2 sm:px-4 py-1.5 sm:py-2 bg-transparent border border-outline-variant text-on-surface-variant rounded-md font-manrope font-bold text-[0.65rem] sm:text-xs hover:bg-surface-container-highest transition-all">
                                            Re-Rent
                                        </a>
                                    </td>
                                </tr>
                            }

                        </tbody>
                    </table>
                </div>
            </div>
        }



    </section>
</main>
