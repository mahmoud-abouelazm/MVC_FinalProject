@page
@model ResetPasswordConfirmationModel
@{
    ViewData["Title"] = "Reset password confirmation";
}

<main class="min-h-screen bg-surface flex items-center justify-center px-4 sm:px-6 lg:px-8">
    <div class="w-full max-w-md">
        <!-- Success Card -->
        <div class="bg-surface-container-lowest rounded-2xl shadow-lg p-6 sm:p-8 border border-outline-variant/15 text-center">
            <!-- Success Icon -->
            <div class="inline-flex items-center justify-center w-16 h-16 bg-secondary-container rounded-full mb-6 animate-pulse">
                <span class="material-symbols-outlined text-secondary text-4xl">verified_user</span>
            </div>

            <!-- Title & Message -->
            <h1 class="font-headline text-2xl sm:text-3xl font-bold text-on-surface mb-2">Password Reset Successfully</h1>
            <p class="text-on-surface-variant text-sm sm:text-base mb-8">
                Your password has been reset. You can now log in with your new password.
            </p>

            <!-- Success Details -->
            <div class="space-y-3 my-8 bg-surface-container-high rounded-lg p-4">
                <div class="flex items-start gap-3">
                    <span class="material-symbols-outlined text-secondary text-xl flex-shrink-0 mt-0.5">check_circle</span>
                    <div class="text-left">
                        <p class="font-label text-xs uppercase tracking-[0.05em] text-on-surface-variant">Status</p>
                        <p class="font-body text-sm font-semibold text-on-surface">Password changed successfully</p>
                    </div>
                </div>
                <div class="flex items-start gap-3">
                    <span class="material-symbols-outlined text-secondary text-xl flex-shrink-0 mt-0.5">security</span>
                    <div class="text-left">
                        <p class="font-label text-xs uppercase tracking-[0.05em] text-on-surface-variant">Security</p>
                        <p class="font-body text-sm font-semibold text-on-surface">Your account is now secure</p>
                    </div>
                </div>
            </div>

            <!-- Login Button -->
            <a asp-page="./Login" class="w-full inline-block py-3 px-6 bg-primary text-on-primary rounded-lg font-manrope font-bold text-sm hover:bg-primary-container transition-all flex items-center justify-center gap-2">
                <span class="material-symbols-outlined text-base">login</span>
                Log In Now
            </a>

            <!-- Additional Info -->
            <div class="mt-8 p-4 rounded-lg bg-surface-container-low border border-outline-variant/15">
                <p class="text-xs text-on-surface-variant font-body">
                    <span class="material-symbols-outlined text-sm align-middle">info</span>
                    <span class="ml-1.5">If you didn't request this password reset, please contact support immediately.</span>
                </p>
            </div>
        </div>

        <!-- Support Section -->
        <div class="mt-6 text-center">
            <p class="text-on-surface-variant text-sm mb-3">Need help?</p>
            <a href="#" class="inline-flex items-center gap-1 text-primary font-semibold text-sm hover:text-primary-container transition-colors">
                <span class="material-symbols-outlined text-base">help</span>
                Contact Support
            </a>
        </div>
    </div>
</main>
