@page
@model ForgotPasswordConfirmation
@{
    ViewData["Title"] = "Forgot password confirmation";
}

<main class="min-h-screen bg-surface flex items-center justify-center px-4 sm:px-6 lg:px-8">
    <div class="w-full max-w-md">
        <!-- Success Card -->
        <div class="bg-surface-container-lowest rounded-2xl shadow-lg p-6 sm:p-8 border border-outline-variant/15 text-center">
            <!-- Success Icon -->
            <div class="inline-flex items-center justify-center w-16 h-16 bg-secondary-container rounded-full mb-6">
                <span class="material-symbols-outlined text-secondary text-4xl">check_circle</span>
            </div>

            <!-- Title & Message -->
            <h1 class="font-headline text-2xl sm:text-3xl font-bold text-on-surface mb-2">Check Your Email</h1>
            <p class="text-on-surface-variant text-sm sm:text-base mb-6">
                We've sent you a password reset link to your email address. Please check your inbox (and spam folder) for further instructions.
            </p>

            <!-- Timeline Info -->
            <div class="space-y-3 my-8 bg-surface-container-high rounded-lg p-4 text-left">
                <div class="flex gap-3">
                    <span class="material-symbols-outlined text-tertiary text-xl flex-shrink-0">schedule</span>
                    <div>
                        <p class="font-label text-xs uppercase tracking-[0.05em] text-on-surface-variant">Link Expires In</p>
                        <p class="font-body text-sm font-semibold text-on-surface">24 hours</p>
                    </div>
                </div>
                <div class="flex gap-3">
                    <span class="material-symbols-outlined text-tertiary text-xl flex-shrink-0">info</span>
                    <div>
                        <p class="font-label text-xs uppercase tracking-[0.05em] text-on-surface-variant">Check Spam</p>
                        <p class="font-body text-sm font-semibold text-on-surface">Email might be in spam folder</p>
                    </div>
                </div>
            </div>

            <!-- Back to Login Button -->
            <a asp-page="./Login" class="w-full inline-block py-3 px-6 bg-primary text-on-primary rounded-lg font-manrope font-bold text-sm hover:bg-primary-container transition-all">
                Back to Login
            </a>

            <!-- Need Help Link -->
            <p class="text-on-surface-variant text-xs mt-6">
                Didn't receive the email? 
                <a asp-page="./ForgotPassword" class="text-primary font-semibold hover:text-primary-container transition-colors">Try again</a>
            </p>
        </div>
    </div>
</main>
