@page
@model ResetPasswordModel
@{
    ViewData["Title"] = "Reset password";
}

<main class="min-h-screen bg-surface flex items-center justify-center px-4 sm:px-6 lg:px-8">
    <div class="w-full max-w-md">
        <!-- Card Container -->
        <div class="bg-surface-container-lowest rounded-2xl shadow-lg p-6 sm:p-8 border border-outline-variant/15">
            <!-- Header -->
            <div class="text-center mb-8">
                <div class="inline-flex items-center justify-center w-12 h-12 bg-primary-fixed-dim rounded-full mb-4">
                    <span class="material-symbols-outlined text-primary">lock_reset</span>
                </div>
                <h1 class="font-headline text-2xl sm:text-3xl font-bold text-on-surface mb-2">Reset Your Password</h1>
                <p class="text-on-surface-variant text-sm sm:text-base">Create a new, strong password for your account.</p>
            </div>

            <!-- Form -->
            <form method="post" class="space-y-5">
                <!-- Validation Summary -->
                <div asp-validation-summary="All" class="hidden bg-error-container/20 border border-error-container rounded-lg p-4 text-error text-sm" id="validationSummary"></div>

                <!-- Hidden Code Input -->
                <input asp-for="Input.Code" type="hidden" />

                <!-- Email Input (Display Only) -->
                <div>
                    <label asp-for="Input.Email" class="block font-label text-[0.6875rem] uppercase tracking-[0.05em] text-on-surface-variant mb-2">Email Address</label>
                    <input asp-for="Input.Email" 
                           class="w-full px-4 py-3 rounded-lg border border-outline-variant bg-surface-container text-on-surface placeholder:text-on-surface-variant/50 transition-all focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent"
                           autocomplete="username" 
                           aria-required="true" 
                           placeholder="name@example.com" />
                    <span asp-validation-for="Input.Email" class="block text-error text-xs mt-1.5 font-body"></span>
                </div>

                <!-- New Password Input -->
                <div>
                    <label asp-for="Input.Password" class="block font-label text-[0.6875rem] uppercase tracking-[0.05em] text-on-surface-variant mb-2">New Password</label>
                    <div class="relative">
                        <input asp-for="Input.Password" 
                               class="w-full px-4 py-3 rounded-lg border border-outline-variant bg-surface text-on-surface placeholder:text-on-surface-variant/50 transition-all focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent"
                               autocomplete="new-password" 
                               aria-required="true" 
                               placeholder="Enter strong password"
                               type="password"
                               id="password" />
                        <button type="button" class="absolute right-3 top-1/2 -translate-y-1/2 text-on-surface-variant hover:text-on-surface transition-colors" onclick="togglePasswordVisibility('password')">
                            <span class="material-symbols-outlined text-xl">visibility</span>
                        </button>
                    </div>
                    <span asp-validation-for="Input.Password" class="block text-error text-xs mt-1.5 font-body"></span>
                    <p class="text-xs text-on-surface-variant mt-2">
                        <span class="material-symbols-outlined text-sm align-middle">info</span>
                        Must be at least 6 characters long
                    </p>
                </div>

                <!-- Confirm Password Input -->
                <div>
                    <label asp-for="Input.ConfirmPassword" class="block font-label text-[0.6875rem] uppercase tracking-[0.05em] text-on-surface-variant mb-2">Confirm Password</label>
                    <div class="relative">
                        <input asp-for="Input.ConfirmPassword" 
                               class="w-full px-4 py-3 rounded-lg border border-outline-variant bg-surface text-on-surface placeholder:text-on-surface-variant/50 transition-all focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent"
                               autocomplete="new-password" 
                               aria-required="true" 
                               placeholder="Re-enter password"
                               type="password"
                               id="confirmPassword" />
                        <button type="button" class="absolute right-3 top-1/2 -translate-y-1/2 text-on-surface-variant hover:text-on-surface transition-colors" onclick="togglePasswordVisibility('confirmPassword')">
                            <span class="material-symbols-outlined text-xl">visibility</span>
                        </button>
                    </div>
                    <span asp-validation-for="Input.ConfirmPassword" class="block text-error text-xs mt-1.5 font-body"></span>
                </div>

                <!-- Password Strength Indicator -->
                <div class="space-y-2">
                    <div class="flex items-center gap-2">
                        <span class="text-xs font-label text-on-surface-variant uppercase tracking-[0.05em]">Password Strength</span>
                        <div class="flex-1 h-1.5 bg-surface-container rounded-full overflow-hidden">
                            <div id="strengthBar" class="h-full w-0 bg-error rounded-full transition-all duration-300"></div>
                        </div>
                    </div>
                    <p id="strengthText" class="text-xs text-on-surface-variant"></p>
                </div>

                <!-- Submit Button -->
                <button type="submit" class="w-full py-3 px-6 bg-primary text-on-primary rounded-lg font-manrope font-bold text-sm hover:bg-primary-container transition-all mt-8 flex items-center justify-center gap-2">
                    <span class="material-symbols-outlined text-base">done</span>
                    Reset Password
                </button>

                <!-- Back to Login Link -->
                <div class="text-center pt-4 border-t border-outline-variant/15">
                    <p class="text-on-surface-variant text-sm">
                        <a asp-page="./Login" class="text-primary font-semibold hover:text-primary-container transition-colors">Back to Login</a>
                    </p>
                </div>
            </form>
        </div>

        <!-- Security Tips -->
        <div class="mt-6 space-y-2">
            <p class="text-xs font-label text-on-surface-variant uppercase tracking-[0.05em]">Password Tips</p>
            <ul class="space-y-2 text-xs text-on-surface-variant">
                <li class="flex gap-2">
                    <span class="material-symbols-outlined text-sm flex-shrink-0">check_circle</span>
                    <span>Use a mix of uppercase, lowercase, numbers, and symbols</span>
                </li>
                <li class="flex gap-2">
                    <span class="material-symbols-outlined text-sm flex-shrink-0">check_circle</span>
                    <span>Avoid using personal information or dictionary words</span>
                </li>
                <li class="flex gap-2">
                    <span class="material-symbols-outlined text-sm flex-shrink-0">check_circle</span>
                    <span>Make it at least 8-12 characters for better security</span>
                </li>
            </ul>
        </div>
    </div>
</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function togglePasswordVisibility(elementId) {
            const input = document.getElementById(elementId);
            input.type = input.type === 'password' ? 'text' : 'password';
        }

        // Show validation summary if there are errors
        const summary = document.getElementById('validationSummary');
        if (summary && summary.textContent.trim().length > 0) {
            summary.classList.remove('hidden');
        }

        // Password strength indicator
        const passwordInput = document.getElementById('password');
        const strengthBar = document.getElementById('strengthBar');
        const strengthText = document.getElementById('strengthText');

        if (passwordInput) {
            passwordInput.addEventListener('input', function() {
                const password = this.value;
                let strength = 0;
                let strengthLevel = 'Weak';
                let strengthColor = 'bg-error';

                // Simple strength calculation
                if (password.length >= 6) strength += 25;
                if (password.length >= 10) strength += 25;
                if (/[a-z]/.test(password) && /[A-Z]/.test(password)) strength += 25;
                const specialChars = /[!@@#$%^&*]/;
                if (/[0-9]/.test(password) && specialChars.test(password)) strength += 25;

                if (strength <= 25) {
                    strengthLevel = 'Weak';
                    strengthColor = 'bg-error';
                } else if (strength <= 50) {
                    strengthLevel = 'Fair';
                    strengthColor = 'bg-warning';
                } else if (strength <= 75) {
                    strengthLevel = 'Good';
                    strengthColor = 'bg-tertiary';
                } else {
                    strengthLevel = 'Strong';
                    strengthColor = 'bg-secondary';
                }

                strengthBar.className = 'h-full ' + strengthColor + ' rounded-full transition-all duration-300';
                strengthBar.style.width = strength + '%';
                strengthText.textContent = strengthLevel;
                strengthText.className = 'text-xs ' + strengthColor.replace('bg-', 'text-');
            });
        }
    </script>
}
