<main class="ml-64 min-h-screen p-12">

    <header class="mb-10">
        <a asp-controller="Authors" asp-action="Index"
           class="inline-flex items-center gap-1 font-manrope text-xs text-on-surface-variant hover:text-primary transition-colors mb-4 uppercase tracking-wider font-semibold">
            <span class="material-symbols-outlined text-base">arrow_back</span>
            Back to Authors
        </a>
        <h2 class="font-noto-serif text-4xl font-bold text-on-surface tracking-tight">
            @(isEdit ? "Edit Author" : "Add New Author")
        </h2>
        <p class="text-on-surface-variant mt-2 font-manrope text-sm">
            @(isEdit ? "Update this author's details." : "Register a new author in the archive.")
        </p>
    </header>

    <div class="max-w-2xl">
        <form asp-controller="Authors" asp-action="@(isEdit ? "Edit" : "Create")" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div class="form-card p-8 space-y-7">

                <div>
                    <label class="field-label" for="Name">Full Name</label>
                    <input class="field-input" id="Name" asp-for="Name"
                           placeholder="e.g. Julianne V. Stone" />
                    <span class="field-validation-error" asp-validation-for="Name"></span>
                </div>

                <div>
                    <label class="field-label" for="Bio">Biography</label>
                    <textarea class="field-input" id="Bio" asp-for="Bio"
                              placeholder="A short biography about the author..." rows="6"></textarea>
                    <span class="field-validation-error" asp-validation-for="Bio"></span>
                </div>

            </div>

            <div class="flex items-center gap-4 mt-6">
                <button type="submit" class="btn-primary">
                    @(isEdit ? "Save Changes" : "Add Author")
                </button>
                <a asp-controller="Authors" asp-action="Index" class="btn-secondary">Cancel</a>
            </div>

        </form>
    </div>
</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
