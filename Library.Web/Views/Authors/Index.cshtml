@model Library.Web.Core.ViewModel.Author.AuthorVM
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Authors";
    ViewData["ActiveNav"] = "Authors";
}
<main class="ml-64 min-h-screen p-12">


    <header class="mb-10 flex justify-between items-end">
        <div>
            <h2 class="font-noto-serif text-4xl font-bold text-on-surface tracking-tight">Authors</h2>
            <p class="text-on-surface-variant mt-2 font-manrope text-sm">Manage registered authors in the archive.</p>
        </div>
        <a asp-controller="Authors" asp-action="Create"
               class="bg-primary text-on-primary px-6 py-2.5 rounded-md font-manrope text-sm font-bold uppercase tracking-wider flex items-center gap-2 shadow-sm hover:bg-primary-container transition-all">
            <span class="material-symbols-outlined text-lg">add</span>
            Add New Author
        </a>
    </header>

    @if (TempData["Success"] != null)
    {
        <div class="mb-6 px-6 py-4 bg-primary-container text-on-primary-container rounded-lg font-manrope text-sm flex items-center gap-3">
            <span class="material-symbols-outlined text-lg">check_circle</span>
            @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="mb-6 px-6 py-4 bg-error-container text-on-error-container rounded-lg font-manrope text-sm flex items-center gap-3">
            <span class="material-symbols-outlined text-lg">error</span>
            @TempData["Error"]
        </div>
    }

    <div class="bg-surface-container-lowest rounded-xl overflow-hidden shadow-[0px_12px_32px_rgba(26,28,26,0.06)] border border-outline-variant/10">

        <div class="bg-tertiary text-on-tertiary px-6 py-4 flex justify-between items-center">
            <span class="font-manrope text-[0.6875rem] uppercase tracking-[0.1em] font-bold">Authors Registry</span>
            <span class="text-[0.6875rem] font-manrope">@Model.TotalAuthors total authors</span>
        </div>

        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-surface-container-low border-b border-outline-variant/10">
                    <th class="px-6 py-4 font-manrope text-[0.6875rem] uppercase tracking-wider text-on-surface-variant font-bold">Name</th>
                    <th class="px-6 py-4 font-manrope text-[0.6875rem] uppercase tracking-wider text-on-surface-variant font-bold">Biography</th>
                    <th class="px-6 py-4 font-manrope text-[0.6875rem] uppercase tracking-wider text-on-surface-variant font-bold text-center">Books</th>
                    <th class="px-6 py-4 font-manrope text-[0.6875rem] uppercase tracking-wider text-on-surface-variant font-bold text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-outline-variant/10">
                @foreach (var author in Model.Authors)
                {
                    <tr class="bg-surface hover:bg-surface-container-low transition-colors group">
                        <td class="px-6 py-5">
                            <div class="flex items-center gap-3">
                                <div class="w-9 h-9 rounded-full bg-secondary-container flex items-center justify-center flex-shrink-0">
                                    <span class="font-noto-serif text-sm font-bold text-on-secondary-container">
                                        @author.Name[0]
                                    </span>
                                </div>
                                <p class="font-noto-serif text-sm font-bold text-on-surface">@author.Name</p>
                            </div>
                        </td>
                        <td class="px-6 py-5">
                            <p class="font-manrope text-xs text-on-surface-variant max-w-xs truncate">
                                @(string.IsNullOrEmpty(author.Bio) ? "—" : author.Bio)
                            </p>
                        </td>
                        <td class="px-6 py-5 text-center">
                            <span class="px-3 py-1 bg-tertiary-fixed text-on-tertiary-fixed text-[10px] font-bold uppercase tracking-tighter rounded-full">
                                @author.BookCount
                            </span>
                        </td>
                        <td class="px-6 py-5 text-right">
                            <div class="flex items-center justify-end gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                                <a asp-controller="Authors" asp-action="Edit" asp-route-id="@author.Id"
                                       class="text-primary p-1.5 hover:bg-primary-fixed/20 rounded transition-colors inline-flex" title="Edit">
                                    <span class="material-symbols-outlined text-lg">edit</span>
                                </a>
                                <form asp-controller="Authors" asp-action="Delete" method="post" class="inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@author.Id" />
                                    <button type="submit"
                                            class="text-error p-1.5 hover:bg-error-container/20 rounded transition-colors"
                                            title="Delete"
                                            onclick="return confirm('Delete «@author.Name»?')">
                                        <span class="material-symbols-outlined text-lg">delete</span>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Authors.Any())
                {
                    <tr>
                        <td colspan="4" class="px-6 py-16 text-center font-manrope text-sm text-on-surface-variant">
                            No authors found. <a asp-controller="Authors" asp-action="Create" class="text-primary underline">Add the first one.</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="px-6 py-4 flex items-center justify-between bg-surface-container-low/50">
            <p class="text-xs font-manrope text-on-surface-variant">
                @if (Model.TotalAuthors > 0)
                {
                    @($"Showing {(Model.CurrentPage - 1) * Model.PageSize + 1}–{Math.Min(Model.CurrentPage * Model.PageSize, Model.TotalAuthors)} of {Model.TotalAuthors} authors")
                }
                else
                {

                    @("No authors")
                }
            </p>
            <div class="flex gap-2">
                @if (Model.CurrentPage > 1)
                {
                    <a asp-controller="Authors" asp-action="Index" asp-route-page="@(Model.CurrentPage - 1)"
                           class="p-2 border border-outline-variant/20 rounded-md hover:bg-white transition-colors">
                        <span class="material-symbols-outlined text-sm">chevron_left</span>
                    </a>
                }
                @if (Model.CurrentPage < Model.TotalPages)
                {
                    <a asp-controller="Authors" asp-action="Index" asp-route-page="@(Model.CurrentPage + 1)"
                           class="p-2 border border-outline-variant/20 rounded-md hover:bg-white transition-colors">
                        <span class="material-symbols-outlined text-sm">chevron_right</span>
                    </a>
                }
            </div>
        </div>

    </div>

</main>