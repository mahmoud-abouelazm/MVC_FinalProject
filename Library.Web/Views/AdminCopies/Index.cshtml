@model Library.Web.Core.ViewModel.Copies.CopyVM
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = Model.FilterBookId.HasValue ? $"Copies — {Model.FilterBookTitle}" : "Copies";
    ViewData["ActiveNav"] = "Copies";
}

<main class="ml-64 min-h-screen p-12">

    @* ── Header ── *@
    <header class="mb-10 flex justify-between items-end">
        <div>
            @if (Model.FilterBookId.HasValue)
            {
                <a asp-controller="AdminCopies" asp-action="Index"
                       class="inline-flex items-center gap-1 font-manrope text-xs text-on-surface-variant hover:text-primary transition-colors mb-3 uppercase tracking-wider font-semibold">
                    <span class="material-symbols-outlined text-base">arrow_back</span>
                    All Copies
                </a>
                <h2 class="font-noto-serif text-4xl font-bold text-on-surface tracking-tight">@Model.FilterBookTitle</h2>
                <p class="text-on-surface-variant mt-1 font-manrope text-sm">Managing physical copies of this title.</p>
            }
            else
            {
                <h2 class="font-noto-serif text-4xl font-bold text-on-surface tracking-tight">Copies</h2>
                <p class="text-on-surface-variant mt-1 font-manrope text-sm">Manage all physical copies across the catalog.</p>
            }
        </div>
        <a asp-controller="AdminCopies" asp-action="Create"
               asp-route-bookId="@Model.FilterBookId"
               class="bg-primary text-on-primary px-6 py-2.5 rounded-md font-manrope text-sm font-bold uppercase tracking-wider flex items-center gap-2 shadow-sm hover:bg-primary-container transition-all">
            <span class="material-symbols-outlined text-lg">add</span>
            Add New Copy
        </a>
    </header>

    @* ── Alerts ── *@
    @if (TempData["Success"] != null)
    {
        <div class="mb-6 px-6 py-4 bg-primary-container text-on-primary-container rounded-lg font-manrope text-sm flex items-center gap-3">
            <span class="material-symbols-outlined text-lg">check_circle</span>
            @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="mb-6 px-6 py-4 bg-error-container text-on-error-container rounded-lg font-manrope text-sm flex items-center gap-3">
            <span class="material-symbols-outlined text-lg">error</span>
            @TempData["Error"]
        </div>
    }

    @* ── Table ── *@
    <div class="bg-surface-container-lowest rounded-xl overflow-hidden shadow-[0px_12px_32px_rgba(26,28,26,0.06)] border border-outline-variant/10">

        <div class="bg-tertiary text-on-tertiary px-6 py-4 flex justify-between items-center">
            <span class="font-manrope text-[0.6875rem] uppercase tracking-[0.1em] font-bold">
                @(Model.FilterBookId.HasValue ? "Copies of This Title" : "All Copies Registry")
            </span>
            <span class="text-[0.6875rem] font-manrope">@Model.TotalCopies total</span>
        </div>

        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-surface-container-low border-b border-outline-variant/10">
                    @if (!Model.FilterBookId.HasValue)
                    {
                        <th class="px-6 py-4 font-manrope text-[0.6875rem] uppercase tracking-wider text-on-surface-variant font-bold">Book</th>
                    }
                    <th class="px-6 py-4 font-manrope text-[0.6875rem] uppercase tracking-wider text-on-surface-variant font-bold">Copy Name</th>
                    <th class="px-6 py-4 font-manrope text-[0.6875rem] uppercase tracking-wider text-on-surface-variant font-bold text-center">Rental Status</th>
                    <th class="px-6 py-4 font-manrope text-[0.6875rem] uppercase tracking-wider text-on-surface-variant font-bold text-center">History</th>
                    <th class="px-6 py-4 font-manrope text-[0.6875rem] uppercase tracking-wider text-on-surface-variant font-bold text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-outline-variant/10">
                @foreach (var copy in Model.Copies)
                {
                    <tr class="bg-surface hover:bg-surface-container-low transition-colors group">

                        @if (!Model.FilterBookId.HasValue)
                        {
                            <td class="px-6 py-4">
                                <a asp-controller="AdminCopies" asp-action="Index"
                                       asp-route-bookId="@copy.BookId"
                                       class="font-noto-serif text-sm font-bold text-on-surface hover:text-primary transition-colors">
                                    @copy.BookTitle
                                </a>
                            </td>
                        }

                        <td class="px-6 py-4">
                            <div class="flex items-center gap-3">
                                <div class="w-8 h-8 rounded-md bg-surface-container-high flex items-center justify-center flex-shrink-0">
                                    <span class="material-symbols-outlined text-on-surface-variant" style="font-size:1rem;">content_copy</span>
                                </div>
                                <span class="font-manrope text-sm font-semibold text-on-surface">@copy.Name</span>
                            </div>
                        </td>

                        <td class="px-6 py-4 text-center">
                            @if (copy.AllowToRental)
                            {
                                <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-primary-container text-on-primary-container text-[10px] font-bold uppercase tracking-wider rounded-full">
                                    <span class="w-1.5 h-1.5 rounded-full bg-primary-fixed-dim inline-block  "></span>
                                    Available
                                </span>
                            }
                            else
                            {
                                <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-surface-container-high text-on-surface-variant text-[10px] font-bold uppercase tracking-wider rounded-full">
                                    <span class="w-1.5 h-1.5 rounded-full bg-outline inline-block"></span>
                                    Restricted
                                </span>
                            }
                        </td>

                        <td class="px-6 py-4 text-center">
                            @if (copy.HasRentals)
                            {
                                <span class="px-3 py-1 bg-tertiary-fixed text-on-tertiary-fixed text-[10px] font-bold uppercase tracking-tighter rounded-full">
                                    @copy.RentalCount rental@(copy.RentalCount == 1 ? "" : "s")
                                </span>
                            }
                            else
                            {
                                <span class="font-manrope text-xs text-on-surface-variant/50">—</span>
                            }
                        </td>

                        <td class="px-6 py-4 text-right">
                            <div class="flex items-center justify-end gap-1 opacity-0 group-hover:opacity-100 transition-opacity">

                                @* Toggle rental availability *@
                                <form asp-controller="AdminCopies" asp-action="ToggleRental" method="post" class="inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@copy.Id" />
                                    <input type="hidden" name="bookId" value="@Model.FilterBookId" />
                                    <button type="submit"
                                            title="@(copy.AllowToRental ? "Restrict from rental" : "Allow rental")"
                                            class="p-1.5 rounded transition-colors @(copy.AllowToRental ? "text-on-surface-variant hover:bg-surface-container-high" : "text-primary hover:bg-primary-fixed/20")">
                                        <span class="material-symbols-outlined text-lg">
                                            @(copy.AllowToRental ? "block" : "check_circle")
                                        </span>
                                    </button>
                                </form>

                                @* Edit *@
                                <a asp-controller="AdminCopies" asp-action="Edit" asp-route-id="@copy.Id"
                                       class="text-primary p-1.5 hover:bg-primary-fixed/20 rounded transition-colors inline-flex" title="Edit">
                                    <span class="material-symbols-outlined text-lg">edit</span>
                                </a>

                                @* Delete — prevented if has rental history *@
                                @if (copy.HasRentals)
                                {
                                    <span class="text-on-surface-variant/30 p-1.5 inline-flex cursor-not-allowed"
                                          title="Cannot delete — copy has rental history">
                                        <span class="material-symbols-outlined text-lg">delete</span>
                                    </span>
                                }
                                else
                                {
                                    <form asp-controller="AdminCopies" asp-action="Delete" method="post" class="inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@copy.Id" />
                                        <input type="hidden" name="bookId" value="@Model.FilterBookId" />
                                        <button type="submit"
                                                class="text-error p-1.5 hover:bg-error-container/20 rounded transition-colors"
                                                title="Delete"
                                                onclick="return confirm('Delete copy «@copy.Name»?')">
                                            <span class="material-symbols-outlined text-lg">delete</span>
                                        </button>
                                    </form>
                                }

                            </div>
                        </td>

                    </tr>
                }

                @if (!Model.Copies.Any())
                {
                    <tr>
                        <td colspan="@(Model.FilterBookId.HasValue ? 4 : 5)"
                            class="px-6 py-16 text-center font-manrope text-sm text-on-surface-variant">
                            No copies found.
                            <a asp-controller="AdminCopies" asp-action="Create"
                               asp-route-bookId="@Model.FilterBookId"
                               class="text-primary underline">Add the first one.</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @* Pagination *@
        <div class="px-6 py-4 flex items-center justify-between bg-surface-container-low/50">
            <p class="text-xs font-manrope text-on-surface-variant">
                @if (Model.TotalCopies > 0)
                {
                    @($"Showing {(Model.CurrentPage - 1) * Model.PageSize + 1}–{Math.Min(Model.CurrentPage * Model.PageSize, Model.TotalCopies)} of {Model.TotalCopies} copies")
                }
                else
                {

                    @("No copies")
                }
            </p>
            <div class="flex gap-2">
                @if (Model.CurrentPage > 1)
                {
                    <a asp-controller="AdminCopies" asp-action="Index"
                           asp-route-page="@(Model.CurrentPage - 1)"
                           asp-route-bookId="@Model.FilterBookId"
                           class="p-2 border border-outline-variant/20 rounded-md hover:bg-white transition-colors">
                        <span class="material-symbols-outlined text-sm">chevron_left</span>
                    </a>
                }
                @if (Model.CurrentPage < Model.TotalPages)
                {
                    <a asp-controller="AdminCopies" asp-action="Index"
                           asp-route-page="@(Model.CurrentPage + 1)"
                           asp-route-bookId="@Model.FilterBookId"
                           class="p-2 border border-outline-variant/20 rounded-md hover:bg-white transition-colors">
                        <span class="material-symbols-outlined text-sm">chevron_right</span>
                    </a>
                }
            </div>
        </div>

    </div>

    @* Info note *@
    <div class="mt-8 px-5 py-4 bg-tertiary-fixed/30 border border-tertiary-fixed/50 rounded-lg flex items-start gap-3 max-w-2xl">
        <span class="material-symbols-outlined text-tertiary mt-0.5" style="font-size:1.1rem;">info</span>
        <p class="font-manrope text-xs text-on-surface-variant leading-relaxed">
            Copies with rental history <strong class="text-on-surface">cannot be deleted</strong> to preserve records.
            Use the <strong class="text-on-surface">Restrict</strong> toggle to prevent new rentals without losing history.
        </p>
    </div>

</main>
