<main class="ml-64 min-h-screen p-12">

    <header class="mb-10">
        <a asp-controller="AdminCopies" asp-action="Index"
           asp-route-bookId="@(Model.BookId > 0 ? Model.BookId : null)"
           class="inline-flex items-center gap-1 font-manrope text-xs text-on-surface-variant hover:text-primary transition-colors mb-4 uppercase tracking-wider font-semibold">
            <span class="material-symbols-outlined text-base">arrow_back</span>
            @(!string.IsNullOrEmpty(Model.BookTitle) ? $"Back to copies of '{Model.BookTitle}'" : "Back to Copies")
        </a>
        <h2 class="font-noto-serif text-4xl font-bold text-on-surface tracking-tight">
            @(isEdit ? "Edit Copy" : "Add New Copy")
        </h2>
        <p class="text-on-surface-variant mt-2 font-manrope text-sm">
            @(isEdit
                ? "Update this copy's details and rental availability."
                : "Register a new physical copy and assign it to a book.")
        </p>
    </header>

    <div class="max-w-xl">
        <form asp-controller="AdminCopies"
              asp-action="@(isEdit ? "Edit" : "Create")"
              method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div class="form-card p-8 space-y-7">

                @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ContainsKey(""))
                {
                    <div class="px-4 py-3 bg-error-container text-on-error-container rounded-lg font-manrope text-sm flex items-center gap-2">
                        <span class="material-symbols-outlined text-base">error</span>
                        @ViewData.ModelState[""]!.Errors.First().ErrorMessage
                    </div>
                }

                <div>
                    <label class="field-label" for="BookId">Book</label>
                    <select class="field-input" id="BookId" asp-for="BookId" asp-items="Model.Books">
                        <option value="">— Select a Book —</option>
                    </select>
                    <span class="field-validation-error" asp-validation-for="BookId"></span>
                </div>

                <div>
                    <label class="field-label" for="Name">Copy Name / Identifier</label>
                    <input class="field-input" id="Name" asp-for="Name"
                           placeholder="e.g. Copy #1, Shelf A-12, COPY-0042" />
                    <span class="field-validation-error" asp-validation-for="Name"></span>
                    <p class="font-manrope text-[.7rem] text-on-surface-variant mt-1.5">
                        Use a name or code that uniquely identifies this physical copy.
                    </p>
                </div>

                <div>
                    <label class="field-label">Rental Availability</label>
                    <div class="grid grid-cols-2 gap-3 mt-1">

                        <label class="flex items-center gap-3 p-4 rounded-lg border-2 cursor-pointer transition-all
                                      @(Model.AllowToRental
                                          ? "border-primary bg-primary/5"
                                          : "border-outline-variant/30 bg-surface-container-low hover:border-outline-variant")">
                            <input type="radio" name="AllowToRental" value="True"
                                   class="sr-only"
                                   @(Model.AllowToRental ? "checked" : "") />
                            <span class="w-4 h-4 rounded-full border-2 flex-shrink-0 flex items-center justify-center
                                         @(Model.AllowToRental ? "border-primary" : "border-outline-variant")">
                                @if (Model.AllowToRental)
                                {
                                    <span class="w-2 h-2 rounded-full bg-primary inline-block"></span>
                                }
                            </span>
                            <div>
                                <p class="font-manrope text-sm font-bold text-on-surface">Allow Rental</p>
                                <p class="font-manrope text-[.7rem] text-on-surface-variant mt-0.5">Available to members</p>
                            </div>
                        </label>

                        <label class="flex items-center gap-3 p-4 rounded-lg border-2 cursor-pointer transition-all
                                      @(!Model.AllowToRental
                                          ? "border-outline bg-surface-container-high"
                                          : "border-outline-variant/30 bg-surface-container-low hover:border-outline-variant")">
                            <input type="radio" name="AllowToRental" value="False"
                                   class="sr-only"
                                   @(!Model.AllowToRental ? "checked" : "") />
                            <span class="w-4 h-4 rounded-full border-2 flex-shrink-0 flex items-center justify-center
                                         @(!Model.AllowToRental ? "border-outline" : "border-outline-variant")">
                                @if (!Model.AllowToRental)
                                {
                                    <span class="w-2 h-2 rounded-full bg-outline inline-block"></span>
                                }
                            </span>
                            <div>
                                <p class="font-manrope text-sm font-bold text-on-surface">Restrict</p>
                                <p class="font-manrope text-[.7rem] text-on-surface-variant mt-0.5">Not available for loan</p>
                            </div>
                        </label>

                    </div>
                    <span class="field-validation-error" asp-validation-for="AllowToRental"></span>
                </div>

            </div>

            <div class="flex items-center gap-4 mt-6">
                <button type="submit" class="btn-primary">
                    @(isEdit ? "Save Changes" : "Add Copy")
                </button>
                <a asp-controller="AdminCopies" asp-action="Index"
                   asp-route-bookId="@(Model.BookId > 0 ? Model.BookId : null)"
                   class="btn-secondary">Cancel</a>
            </div>

        </form>
    </div>
</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
