@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<main class="min-h-screen flex items-center justify-center px-4 pt-32 pb-20">
    <div class="w-full max-w-2xl">
        <!-- Error Icon & Header -->
        <div class="text-center mb-12 space-y-6">
            <div class="flex justify-center mb-6">
                <div class="relative">
                    <div class="absolute inset-0 blur-[80px] opacity-20 bg-error rounded-full scale-75"></div>
                    <span class="material-symbols-outlined text-9xl text-error relative">error</span>
                </div>
            </div>
            
            <div class="space-y-3">
                <h1 class="font-headline text-6xl md:text-7xl font-bold text-error">Oops!</h1>
                <h2 class="font-headline text-2xl md:text-3xl text-on-surface">An error occurred while processing your request</h2>
            </div>
        </div>

        <!-- Error Details Card -->
        <div class="bg-surface-container-lowest p-8 md:p-12 rounded-xl border border-outline-variant/15 shadow-sm space-y-8 mb-8">
            
            <!-- Error Message -->
            <div class="space-y-3">
                <div class="flex items-center gap-3">
                    <span class="material-symbols-outlined text-error text-xl">warning</span>
                    <h3 class="font-headline text-xl font-bold text-on-surface">What Happened?</h3>
                </div>
                <p class="font-body text-on-surface-variant leading-relaxed text-lg">
                    Something unexpected occurred while we were processing your request. Our team has been notified of this issue and we're working to resolve it as quickly as possible.
                </p>
            </div>

            <!-- Request ID (if available) -->
            @if (Model.ShowRequestId)
            {
                <div class="space-y-3 p-6 bg-surface-container-low rounded-lg border-l-4 border-secondary">
                    <div class="flex items-center gap-2">
                        <span class="material-symbols-outlined text-secondary">info</span>
                        <span class="font-label text-sm font-bold uppercase tracking-widest text-on-surface-variant">Request ID</span>
                    </div>
                    <code class="block font-mono text-sm text-on-surface break-all bg-surface-container-lowest px-4 py-3 rounded-lg border border-outline-variant/15">
                        @Model.RequestId
                    </code>
                    <p class="font-body text-xs text-on-surface-variant">
                        Please provide this ID when contacting support to help us investigate this issue faster.
                    </p>
                </div>
            }

            <!-- Development Mode Info -->
          
        </div>

        <!-- Action Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="javascript:history.back()" 
               class="flex items-center justify-center gap-2 px-6 py-4 rounded-lg font-body font-bold text-lg border-2 border-outline-variant/30 text-on-surface hover:bg-surface-container-low transition-all duration-300 active:scale-95">
                <span class="material-symbols-outlined">arrow_back</span>
                <span>Go Back</span>
            </a>
            
            <a href="/" 
               class="flex items-center justify-center gap-2 px-6 py-4 rounded-lg font-body font-bold text-lg bg-primary text-on-primary hover:bg-primary-container transition-all duration-300 shadow-md active:scale-95">
                <span class="material-symbols-outlined">home</span>
                <span>Home</span>
            </a>
        </div>

        <!-- Help Section -->
        <div class="mt-12 pt-8 border-t border-outline-variant/15 space-y-6">
            <h3 class="font-headline text-center text-xl font-bold text-on-surface">Need Help?</h3>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <!-- Documentation -->
                <a href="#" class="p-6 rounded-lg bg-surface-container-low hover:bg-surface-container transition-colors duration-300 group">
                    <div class="flex items-start gap-3">
                        <span class="material-symbols-outlined text-primary text-2xl group-hover:scale-110 transition-transform">description</span>
                        <div>
                            <h4 class="font-body font-bold text-on-surface mb-1">Documentation</h4>
                            <p class="font-body text-sm text-on-surface-variant">Browse our help documentation</p>
                        </div>
                    </div>
                </a>

                <!-- Contact Support -->
                <a href="#" class="p-6 rounded-lg bg-surface-container-low hover:bg-surface-container transition-colors duration-300 group">
                    <div class="flex items-start gap-3">
                        <span class="material-symbols-outlined text-primary text-2xl group-hover:scale-110 transition-transform">mail</span>
                        <div>
                            <h4 class="font-body font-bold text-on-surface mb-1">Contact Support</h4>
                            <p class="font-body text-sm text-on-surface-variant">Reach out to our team</p>
                        </div>
                    </div>
                </a>

                <!-- Report Bug -->
                <a href="#" class="p-6 rounded-lg bg-surface-container-low hover:bg-surface-container transition-colors duration-300 group">
                    <div class="flex items-start gap-3">
                        <span class="material-symbols-outlined text-primary text-2xl group-hover:scale-110 transition-transform">bug_report</span>
                        <div>
                            <h4 class="font-body font-bold text-on-surface mb-1">Report Bug</h4>
                            <p class="font-body text-sm text-on-surface-variant">Help us improve the service</p>
                        </div>
                    </div>
                </a>
            </div>
        </div>

        <!-- Footer Note -->
        <div class="mt-12 text-center">
            <p class="font-body text-sm text-on-surface-variant">
                Error ID: <code class="bg-surface-container-low px-2 py-1 rounded text-xs">@(Model.ShowRequestId ? Model.RequestId : "N/A")</code>
            </p>
            <p class="font-body text-xs text-on-surface-variant/60 mt-2">
                © 2024 The Editorial Archive. All Rights Reserved.
            </p>
        </div>
    </div>
</main>
