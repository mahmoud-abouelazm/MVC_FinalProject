@using Library.Web.Core.Models
@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager

@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    var isAuthorsPage = currentController == "Home" && currentAction == "Authors";
    var currentUser = User.Identity?.IsAuthenticated == true ? await UserManager.GetUserAsync(User) : null;
    var userName = currentUser?.FullName ?? User.Identity?.Name ?? "User";
    var userEmail = currentUser?.Email ?? User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Email)?.Value ?? userName;
}

<nav role="navigation" aria-label="Primary" class="fixed top-0 inset-x-0 z-50 bg-[#f9faf6]/90 dark:bg-[#1a1c1a]/90 backdrop-blur-md shadow-[0px_12px_32px_rgba(26,28,26,0.06)]">
    <div class="max-w-[1600px] mx-auto px-4 sm:px-6 md:px-12 py-3 md:py-4">
        <div class="flex items-center justify-between gap-3">
            <a asp-action="Index" asp-controller="Home" class="font-noto-serif italic font-bold text-[#1a1c1a] dark:text-[#f9faf6] text-lg sm:text-xl tracking-tight whitespace-nowrap">The Editorial Archive</a>

            <div class="hidden lg:flex items-center gap-4 xl:gap-6">
                <a class="@(currentController == "Home" && !isAuthorsPage ? "text-[#004b23] font-bold border-b-2 border-[#004b23] pb-1" : "text-[#1a1c1a]/70 dark:text-[#f9faf6]/70") transition-colors duration-300" asp-action="Index" asp-controller="Home">Home</a>
                <a class="@(currentController == "Books" ? "text-[#004b23] font-bold border-b-2 border-[#004b23] pb-1" : "text-[#1a1c1a]/70 dark:text-[#f9faf6]/70") transition-colors duration-300" asp-action="Index" asp-controller="Books">Books</a>
                <a class="@(isAuthorsPage ? "text-[#004b23] font-bold border-b-2 border-[#004b23] pb-1" : "text-[#1a1c1a]/70 dark:text-[#f9faf6]/70") transition-colors duration-300" asp-action="Authors" asp-controller="Home">Authors</a>
            </div>

            <div class="hidden lg:flex items-center gap-3">
                <form asp-action="Index" asp-controller="Books" method="get" class="bg-surface-container-highest rounded-full px-4 py-2 flex items-center gap-2 w-48 xl:w-64">
                    <button type="submit" class="inline-flex items-center text-primary hover:text-primary-container transition-colors" aria-label="Search books">
                        <span class="material-symbols-outlined text-primary text-lg">search</span>
                    </button>
                    <input name="search" class="bg-transparent border-none focus:ring-0 text-sm w-full font-body" placeholder="Search book..." type="text" />
                </form>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="relative">
                        <button id="account-menu-button" type="button" class="text-primary hover:text-primary-container transition-colors inline-flex items-center" title="Account" aria-label="Account" aria-haspopup="menu" aria-expanded="false" aria-controls="account-menu">
                            <span class="material-symbols-outlined text-3xl">account_circle</span>
                        </button>
                        <div id="account-menu" class="hidden absolute right-0 mt-2 w-72 bg-surface-container-lowest border border-outline-variant/30 rounded-xl shadow-xl p-4 z-50">
                            <div class="mb-3 pb-3 border-b border-outline-variant/20">
                                <p class="font-body text-sm font-bold text-on-surface truncate">Hi , @userName</p>
                                <p class="font-body text-xs text-on-surface-variant truncate">@userEmail</p>
                            </div>
                            <a asp-area="Identity" asp-page="/Manage/Profile" class="mb-3 w-full inline-flex items-center justify-center px-4 py-2.5 rounded-lg font-body font-bold text-sm uppercase tracking-widest text-on-surface border border-outline-variant/30 hover:bg-surface-container-low transition-all duration-300">
                                Profile
                            </a>
                            <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                                <button type="submit" class="w-full text-center px-4 py-2.5 rounded-lg font-body font-bold text-sm uppercase tracking-widest text-on-primary bg-primary hover:bg-primary-container transition-all duration-300 shadow-md active:scale-95">
                                    Logout
                                </button>
                            </form>
                        </div>
                    </div>
                }
                else
                {
                    <a asp-area="Identity" asp-page="/Account/Register" class="px-4 py-2 rounded-lg font-body font-bold text-sm uppercase tracking-widest text-on-surface hover:bg-surface-container-low transition-all duration-300 border border-outline-variant/30">
                        Register
                    </a>
                    <a asp-area="Identity" asp-page="/Account/Login" class="px-4 py-2 rounded-lg font-body font-bold text-sm uppercase tracking-widest text-on-primary bg-primary hover:bg-primary-container transition-all duration-300 shadow-md active:scale-95">
                        Login
                    </a>
                }
            </div>

            <button id="mobile-menu-button" type="button" class="lg:hidden inline-flex items-center justify-center rounded-lg p-2 text-primary hover:bg-surface-container-highest transition-colors" aria-controls="mobile-menu" aria-expanded="false" aria-label="Toggle navigation menu">
                <span id="mobile-menu-icon" class="material-symbols-outlined">menu</span>
            </button>
        </div>

        <div id="mobile-menu" aria-hidden="true" class="lg:hidden hidden pt-4 pb-2 space-y-4 border-t border-outline-variant/30 mt-3">
            <form asp-action="Index" asp-controller="Books" method="get" class="bg-surface-container-highest rounded-full px-4 py-2 flex items-center gap-2">
                <button type="submit" class="inline-flex items-center text-primary hover:text-primary-container transition-colors" aria-label="Search books">
                    <span class="material-symbols-outlined text-primary text-lg">search</span>
                </button>
                <input name="search" class="bg-transparent border-none focus:ring-0 text-sm w-full font-body" placeholder="Search book..." type="text" />
            </form>

            <div class="flex flex-col gap-3 font-noto-serif text-base tracking-tight">
                <a class="@(currentController == "Home" && !isAuthorsPage ? "text-[#004b23] font-bold" : "text-[#1a1c1a]/80 dark:text-[#f9faf6]/80")" asp-action="Index" asp-controller="Home">Home</a>
                <a class="@(currentController == "Books" ? "text-[#004b23] font-bold" : "text-[#1a1c1a]/80 dark:text-[#f9faf6]/80")" asp-action="Index" asp-controller="Books">Books</a>
                <a class="@(isAuthorsPage ? "text-[#004b23] font-bold" : "text-[#1a1c1a]/80 dark:text-[#f9faf6]/80")" asp-action="Authors" asp-controller="Home">Authors</a>
            </div>

            <div class="pt-2 border-t border-outline-variant/30">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="space-y-3">
                        <div>
                            <p class="font-body text-sm font-bold text-on-surface truncate">@userName</p>
                            <p class="font-body text-xs text-on-surface-variant break-all">@userEmail</p>
                        </div>
                        <a asp-area="Identity" asp-page="/Manage/Profile" class="block w-full text-center px-4 py-2.5 rounded-lg font-body font-bold text-sm uppercase tracking-widest text-on-surface hover:bg-surface-container-low transition-all duration-300 border border-outline-variant/30">
                            Profile
                        </a>
                        <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                            <button type="submit" class="w-full text-center px-4 py-2.5 rounded-lg font-body font-bold text-sm uppercase tracking-widest text-on-primary bg-primary hover:bg-primary-container transition-all duration-300 shadow-md active:scale-95">
                                Logout
                            </button>
                        </form>
                    </div>
                }
                else
                {
                    <div class="flex items-center gap-3">
                        <a asp-area="Identity" asp-page="/Account/Register" class="flex-1 text-center px-4 py-2.5 rounded-lg font-body font-bold text-sm uppercase tracking-widest text-on-surface hover:bg-surface-container-low transition-all duration-300 border border-outline-variant/30">
                            Register
                        </a>
                        <a asp-area="Identity" asp-page="/Account/Login" class="flex-1 text-center px-4 py-2.5 rounded-lg font-body font-bold text-sm uppercase tracking-widest text-on-primary bg-primary hover:bg-primary-container transition-all duration-300 shadow-md active:scale-95">
                            Login
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</nav>

<script>
    (function () {
        const button = document.getElementById('mobile-menu-button');
        const menu = document.getElementById('mobile-menu');
        const icon = document.getElementById('mobile-menu-icon');
        const mobileNavLinks = menu ? menu.querySelectorAll('a') : [];
        const accountButton = document.getElementById('account-menu-button');
        const accountMenu = document.getElementById('account-menu');

        if (!button || !menu || !icon) return;

        const openMenu = function () {
            menu.classList.remove('hidden');
            icon.textContent = 'close';
            button.setAttribute('aria-expanded', 'true');
            menu.setAttribute('aria-hidden', 'false');
        };

        const closeMenu = function () {
            menu.classList.add('hidden');
            icon.textContent = 'menu';
            button.setAttribute('aria-expanded', 'false');
            menu.setAttribute('aria-hidden', 'true');
        };

        button.addEventListener('click', function () {
            const isHidden = menu.classList.contains('hidden');
            if (isHidden) {
                openMenu();
                return;
            }

            closeMenu();
        });

        mobileNavLinks.forEach(function (link) {
            link.addEventListener('click', closeMenu);
        });

        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') {
                closeMenu();
            }
        });

        window.addEventListener('resize', function () {
            if (window.innerWidth >= 1024) {
                closeMenu();
            }
        });

        if (accountButton && accountMenu) {
            const closeAccountMenu = function () {
                accountMenu.classList.add('hidden');
                accountButton.setAttribute('aria-expanded', 'false');
            };

            accountButton.addEventListener('click', function (e) {
                e.stopPropagation();
                const isHidden = accountMenu.classList.contains('hidden');
                accountMenu.classList.toggle('hidden');
                accountButton.setAttribute('aria-expanded', isHidden ? 'true' : 'false');
            });

            document.addEventListener('click', function (e) {
                if (!accountMenu.contains(e.target) && !accountButton.contains(e.target)) {
                    closeAccountMenu();
                }
            });

            document.addEventListener('keydown', function (e) {
                if (e.key === 'Escape') {
                    closeAccountMenu();
                }
            });
        }
    })();
</script>
