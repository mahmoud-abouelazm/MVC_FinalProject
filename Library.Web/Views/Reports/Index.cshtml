@using System.Text.Json
@model Library.Web.Core.ViewModel.Reports.ReportsVM
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Reports";
    ViewData["ActiveNav"] = "Reports";
}

<main class="ml-0 md:ml-64 min-h-screen pt-20 md:pt-12 px-4 sm:px-6 md:px-12 pb-8 md:pb-12">

    <header class="mb-10">
        <h2 class="font-noto-serif text-4xl font-bold text-on-surface tracking-tight">Reports</h2>
        <p class="text-on-surface-variant mt-1 font-manrope text-sm">Quick overview of users, revenue, books, and authors across @Model.ReportYear.</p>
    </header>

    <section class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-4 md:gap-6 mb-10">

        <div class="bg-surface-container-lowest rounded-xl p-6 border border-outline-variant/10 shadow-sm flex flex-col justify-between relative overflow-hidden group">
            <div class="relative z-10">
                <p class="font-manrope text-[0.6875rem] uppercase tracking-[0.1em] font-bold text-on-surface-variant mb-2">Users</p>
                <h4 class="font-noto-serif text-3xl font-bold text-on-surface">@Model.TotalUsers</h4>
            </div>
            <div class="absolute -right-4 -bottom-4 opacity-5 group-hover:opacity-10 transition-opacity duration-500">
                <span class="material-symbols-outlined" style="font-size:7rem;">group</span>
            </div>
        </div>

        <div class="bg-tertiary text-on-tertiary rounded-xl p-6 shadow-sm flex flex-col justify-between relative overflow-hidden group">
            <div class="relative z-10">
                <p class="font-manrope text-[0.6875rem] uppercase tracking-[0.1em] font-bold opacity-70 mb-2">Revenue</p>
                <h4 class="font-noto-serif text-3xl font-bold">$@Model.TotalRevenue.ToString("0.00")</h4>
            </div>
            <div class="absolute -right-4 -bottom-4 opacity-10 group-hover:opacity-20 transition-opacity duration-500">
                <span class="material-symbols-outlined" style="font-size:7rem;">payments</span>
            </div>
        </div>

        <div class="bg-primary-container/10 rounded-xl p-6 border border-primary/10 shadow-sm flex flex-col justify-between relative overflow-hidden group">
            <div class="relative z-10">
                <p class="font-manrope text-[0.6875rem] uppercase tracking-[0.1em] font-bold text-on-primary-container mb-2">Books</p>
                <h4 class="font-noto-serif text-3xl font-bold text-primary">@Model.TotalBooks</h4>
                <p class="font-manrope text-[11px] text-on-surface-variant mt-1">Active books only</p>
            </div>
            <div class="absolute -right-4 -bottom-4 opacity-10 group-hover:opacity-20 transition-opacity duration-500">
                <span class="material-symbols-outlined text-primary" style="font-size:7rem;">menu_book</span>
            </div>
        </div>

        <div class="bg-error-container/30 rounded-xl p-6 border border-error/10 shadow-sm flex flex-col justify-between relative overflow-hidden group">
            <div class="relative z-10">
                <p class="font-manrope text-[0.6875rem] uppercase tracking-[0.1em] font-bold text-on-error-container mb-2">Authors</p>
                <h4 class="font-noto-serif text-3xl font-bold text-error">@Model.TotalAuthors</h4>
            </div>
            <div class="absolute -right-4 -bottom-4 opacity-10 group-hover:opacity-20 transition-opacity duration-500">
                <span class="material-symbols-outlined text-error" style="font-size:7rem;">history_edu</span>
            </div>
        </div>

    </section>

    <section class="grid grid-cols-1 xl:grid-cols-2 gap-6 mb-6">
        <div class="bg-surface-container-lowest rounded-xl overflow-hidden shadow-[0px_12px_32px_rgba(26,28,26,0.06)] border border-outline-variant/10 p-6">
            <h3 class="font-noto-serif text-xl font-bold text-on-surface tracking-tight">Users by Month</h3>
            <p class="text-on-surface-variant font-manrope text-xs mt-1">Distinct active users from rentals.</p>
            <div class="h-[300px] mt-4">
                <canvas id="usersChart"></canvas>
            </div>
        </div>

        <div class="bg-surface-container-lowest rounded-xl overflow-hidden shadow-[0px_12px_32px_rgba(26,28,26,0.06)] border border-outline-variant/10 p-6">
            <h3 class="font-noto-serif text-xl font-bold text-on-surface tracking-tight">Revenue by Month</h3>
            <p class="text-on-surface-variant font-manrope text-xs mt-1">Collected amount on returned rentals.</p>
            <div class="h-[300px] mt-4">
                <canvas id="revenueChart"></canvas>
            </div>
        </div>
    </section>

    <section class="grid grid-cols-1 xl:grid-cols-2 gap-6 mb-6">
        <div class="bg-surface-container-lowest rounded-xl overflow-hidden shadow-[0px_12px_32px_rgba(26,28,26,0.06)] border border-outline-variant/10 p-6">
            <h3 class="font-noto-serif text-xl font-bold text-on-surface tracking-tight">Rentals by Month</h3>
            <p class="text-on-surface-variant font-manrope text-xs mt-1">Total rentals created each month.</p>
            <div class="h-[300px] mt-4">
                <canvas id="rentalsChart"></canvas>
            </div>
        </div>

        <div class="bg-surface-container-lowest rounded-xl overflow-hidden shadow-[0px_12px_32px_rgba(26,28,26,0.06)] border border-outline-variant/10 p-6">
            <h3 class="font-noto-serif text-xl font-bold text-on-surface tracking-tight">Authors by Month</h3>
            <p class="text-on-surface-variant font-manrope text-xs mt-1">Distinct rented authors each month.</p>
            <div class="h-[300px] mt-4">
                <canvas id="authorsChart"></canvas>
            </div>
        </div>
    </section>

    <section class="bg-surface-container-lowest rounded-xl overflow-hidden shadow-[0px_12px_32px_rgba(26,28,26,0.06)] border border-outline-variant/10 p-6 md:p-8">
        <h3 class="font-noto-serif text-xl font-bold text-on-surface tracking-tight">Books by Category</h3>
        <p class="text-on-surface-variant font-manrope text-xs mt-1">Category distribution for active books.</p>
        <div class="h-[340px] mt-4">
            <canvas id="categoriesChart"></canvas>
        </div>
    </section>
</main>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        (() => {
            const monthLabels = @Html.Raw(JsonSerializer.Serialize(Model.MonthLabels));
            const usersByMonth = @Html.Raw(JsonSerializer.Serialize(Model.UsersByMonth));
            const revenueByMonth = @Html.Raw(JsonSerializer.Serialize(Model.RevenueByMonth));
            const rentalsByMonth = @Html.Raw(JsonSerializer.Serialize(Model.RentalsByMonth));
            const authorsByMonth = @Html.Raw(JsonSerializer.Serialize(Model.AuthorsByMonth));
            const categoryLabels = @Html.Raw(JsonSerializer.Serialize(Model.CategoryLabels));
            const categoryBookCounts = @Html.Raw(JsonSerializer.Serialize(Model.CategoryBookCounts));

            const sharedScale = {
                beginAtZero: true,
                ticks: { precision: 0 },
                grid: { color: 'rgba(112,121,112,0.12)' }
            };

            new Chart(document.getElementById('usersChart'), {
                type: 'line',
                data: {
                    labels: monthLabels,
                    datasets: [{
                        label: 'Users',
                        data: usersByMonth,
                        borderColor: 'rgba(4,109,63,1)',
                        backgroundColor: 'rgba(4,109,63,0.18)',
                        fill: true,
                        tension: 0.35,
                        pointRadius: 3,
                        pointHoverRadius: 5
                    }]
                },
                options: {
                    maintainAspectRatio: false,
                    scales: { y: sharedScale }
                }
            });

            new Chart(document.getElementById('revenueChart'), {
                type: 'bar',
                data: {
                    labels: monthLabels,
                    datasets: [{
                        label: 'Revenue',
                        data: revenueByMonth,
                        borderColor: 'rgba(16,44,70,1)',
                        backgroundColor: 'rgba(16,44,70,0.72)',
                        borderRadius: 8,
                        borderWidth: 1
                    }]
                },
                options: {
                    maintainAspectRatio: false,
                    scales: { y: sharedScale }
                }
            });

            new Chart(document.getElementById('rentalsChart'), {
                type: 'line',
                data: {
                    labels: monthLabels,
                    datasets: [{
                        label: 'Rentals',
                        data: rentalsByMonth,
                        borderColor: 'rgba(149,174,207,1)',
                        backgroundColor: 'rgba(149,174,207,0.22)',
                        fill: true,
                        stepped: true,
                        pointRadius: 2
                    }]
                },
                options: {
                    maintainAspectRatio: false,
                    scales: { y: sharedScale }
                }
            });

            new Chart(document.getElementById('authorsChart'), {
                type: 'line',
                data: {
                    labels: monthLabels,
                    datasets: [{
                        label: 'Authors',
                        data: authorsByMonth,
                        borderColor: 'rgba(186,26,26,1)',
                        backgroundColor: 'rgba(186,26,26,0.22)',
                        pointBackgroundColor: 'rgba(186,26,26,1)',
                        fill: true,
                        tension: 0.35,
                        pointRadius: 3,
                        pointHoverRadius: 5
                    }]
                },
                options: {
                    maintainAspectRatio: false,
                    scales: { y: sharedScale }
                }
            });

            new Chart(document.getElementById('categoriesChart'), {
                type: 'doughnut',
                data: {
                    labels: categoryLabels,
                    datasets: [{
                        label: 'Books',
                        data: categoryBookCounts,
                        backgroundColor: [
                            'rgba(4,109,63,0.82)',
                            'rgba(16,44,70,0.82)',
                            'rgba(149,174,207,0.82)',
                            'rgba(186,26,26,0.82)',
                            'rgba(84,94,118,0.82)',
                            'rgba(129,217,161,0.82)',
                            'rgba(175,201,234,0.82)'
                        ],
                        borderColor: 'rgba(255,255,255,0.9)',
                        borderWidth: 2
                    }]
                },
                options: {
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom'
                        }
                    }
                }
            });
        })();
    </script>
}
