@model List<Category> 

<br />

<table class="table">
    <thead class="thead-dark">
        <tr>
            <th scope="col">#</th>
            <th scope="col">Name</th>
            

        </tr>
    </thead>
    <tbody>

        @foreach (var category in Model)
        {
            <tr>
                <td>@category.Id</td>
                <td><a asp-action="CategoryFilter" asp-route-CategoryId="@category.Id"><b> @category.Name  </b> </a></td>
                
            </tr>
        }
 
    </tbody>
</table>