                                <div class="flex items-center gap-3">
                                    <img alt="User profile" class="w-8 h-8 object-cover rounded-full shadow-sm grayscale" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCZyPCGq239lPU4g00p8AOAxooEAmAmoHsRmbC9n9KzuffADfX-Tr2s3lTYBPV5Pa8n5-0o81He1xjCevP5mQ_iMNDJXv2VChXNmsus835o9WqfMCqTGsw4yzMNyPSS2B63XuF7vCVGTwT9trOKjQjjjou_NZQXlVFJ7CjcITbcKWgTQu4kmVWtIIA2tbM95HPEhCr7BMVRUgtFMzHQanIaWDANtJoZpfyKPfsd7-8QPKRE4z0cjA143eG6180hHhdHZyNSJlrp-8dc" />
                                    <div>
                                        <p class="font-bold text-on-surface">Julian Thorne</p>
                                        <p class="text-[0.65rem] font-bold text-outline uppercase tracking-wider">Associate</p>
                                    </div>
                                </div>
                            </td>
                            <td class="text-on-surface-variant">thorne.j@freelance.com</td>
                            <td class="text-on-surface-variant">Jan 18, 2024</td>
