                                <div class="flex items-center justify-end gap-3">
                                    <a class="text-primary hover:underline text-xs font-bold" href="#">See Details</a>
                                    <button class="px-3 py-1 bg-primary-container text-on-primary-container text-[0.65rem] font-bold uppercase rounded-full hover:bg-primary hover:text-on-primary transition-all">Activate</button>
                                </div>
                            </td>
                        </tr>
                        <tr class="hover:bg-surface-container-low transition-colors">
                            <td>
                                <div class="flex items-center gap-3">
                                    <img alt="User profile" class="w-8 h-8 object-cover rounded-full shadow-sm" src="https://lh3.googleusercontent.com/aida-public/AB6AXuB_LAHI-qv7xnCQdSsfRMk0Xe8OCU5XQkHNrnkZbcoI0gVcD-RvGlTVdDdCCMQOH7dpV4zQKCJ5buzBLnvxV0OfzEDpbeSSZUR0m7mgOk7l-0Z3r25eqYpJuAk7KVgBDSZqAJ8IoAzx1xSrBOM9K-azoH87C8Nsf7fotYC6zQTIdFj9b4VEocwUPs63s7CSHyrhigoruDs9eNvz_jG6F7j1dS9bME_IJ6albMiEa5qpZeCW2Q-mvGVppMb-fd2-zLINsMjL0-jJA_jo" />
                                    <div>
                                        <p class="font-bold text-on-surface">Elena Ross</p>
                                        <p class="text-[0.65rem] font-bold text-primary-fixed-dim uppercase tracking-wider">Fellow</p>
                                    </div>
                                </div>
                            </td>
                            <td class="text-on-surface-variant">e.ross@vam.ac.uk</td>
                            <td class="text-on-surface-variant">Dec 22, 2023</td>
                            <td class="text-right">
                                <div class="flex items-center justify-end gap-3">
                                    <a class="text-primary hover:underline text-xs font-bold" href="#">See Details</a>
                                    <button class="px-3 py-1 bg-error-container text-error text-[0.65rem] font-bold uppercase rounded-full hover:bg-error hover:text-on-error transition-all">Deactivate</button>
                                </div>
                            </td>
                        </tr> *@
                    </tbody>
                </table>
            </div>
            <div class="p-4 border-t border-surface-container flex justify-center">
                <nav class="flex gap-1">
                    @if (Model.CurrentPage > 1)
                    {
                        <a asp-route-page="1" class="w-8 h-8 rounded flex items-center justify-center hover:bg-surface-container-low text-xs font-bold">«</a>
                    }
                    
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        @if (i == 1 || i == Model.TotalPages || (i >= Model.CurrentPage - 1 && i <= Model.CurrentPage + 1))
                        {
                            @if (i == Model.CurrentPage)
                            {
                                <button class="w-8 h-8 rounded flex items-center justify-center bg-surface-container-high text-xs font-bold" disabled>@i</button>
                            }
                            else
                            {
                                <a asp-route-page="@i" class="w-8 h-8 rounded flex items-center justify-center hover:bg-surface-container-low text-xs font-bold">@i</a>
                            }
                        }
                        else if (i == 2 && Model.CurrentPage > 3)
                        {
                            <span class="px-2 self-center opacity-30">...</span>
                        }
                        else if (i == Model.TotalPages - 1 && Model.CurrentPage < Model.TotalPages - 2)
                        {
                            <span class="px-2 self-center opacity-30">...</span>
                        }
                    }
                    
                    @if (Model.CurrentPage < Model.TotalPages)
                    {
                        <a asp-route-page="@(Model.CurrentPage + 1)" class="w-8 h-8 rounded flex items-center justify-center hover:bg-surface-container-low text-xs font-bold">»</a>
                    }
                </nav>
            </div>
        </section>
       
    </main>
