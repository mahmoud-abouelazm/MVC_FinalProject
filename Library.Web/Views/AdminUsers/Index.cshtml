@model UserVM
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
     ViewData["ActiveNav"] = "Users";

}
    <style>
        .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        body { font-family: 'Manrope', sans-serif; }
        h1, h2, h3 { font-family: 'Noto Serif', serif; }
        /* Custom table styles for consistency with Archive Catalog */
        .catalog-table th {
        text-align: left;
        padding: 1rem 1.5rem;
        font-size: 0.65rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-weight: 700;
        color: #404941;
        border-bottom: 1px solid #e2e3df;
        }
        .catalog-table td {
        padding: 1rem 1.5rem;
        font-size: 0.875rem;
        vertical-align: middle;
        border-bottom: 1px solid #f3f4f0;
        }
    </style>

    <!-- Main Content -->
    <main class="md:ml-64 pt-24 pb-12 px-8 min-h-screen">

        <!-- Header Section -->
        <section class="mb-12">
            <h2 class="text-3xl font-headline font-bold text-primary mb-2">User Community Management</h2>
            <p class="font-body text-on-surface-variant max-w-2xl">Oversee the scholarly community, manage member access tiers, and monitor engagement across the global archival network.</p>
        </section>


         <section class="grid grid-cols-4 gap-6 mb-10">

     <div class="bg-surface-container-lowest rounded-xl p-6 border border-outline-variant/10 shadow-sm flex flex-col justify-between relative overflow-hidden group">
         <div class="relative z-10">
             <p class="font-manrope text-[0.6875rem] uppercase tracking-[0.1em] font-bold text-on-surface-variant mb-2">Total Members</p>
             <h4 class="font-noto-serif text-3xl font-bold text-on-surface">@Model.TotalUsers</h4>
         </div>
         <div class="absolute -right-4 -bottom-4 opacity-5 group-hover:opacity-10 transition-opacity duration-500">
             <span class="material-symbols-outlined" style="font-size:7rem;">autorenew</span>
         </div>
     </div>

     <div class="bg-error-container/30 rounded-xl p-6 border border-error/10 shadow-sm flex flex-col justify-between relative overflow-hidden group">
         <div class="relative z-10">
             <p class="font-manrope text-[0.6875rem] uppercase tracking-[0.1em] font-bold text-on-error-container mb-2">Not Verified</p>
             <h4 class="font-noto-serif text-3xl font-bold text-error">@Model.NotActiveUsers</h4>
         </div>
         <div class="absolute -right-4 -bottom-4 opacity-10 group-hover:opacity-20 transition-opacity duration-500">
             <span class="material-symbols-outlined text-error" style="font-size:7rem;">warning</span>
         </div>
     </div>

     <div class="bg-primary-container/10 rounded-xl p-6 border border-primary/10 shadow-sm flex flex-col justify-between relative overflow-hidden group">
         <div class="relative z-10">
             <p class="font-manrope text-[0.6875rem] uppercase tracking-[0.1em] font-bold text-on-primary-container mb-2">Verified Users</p>
             <h4 class="font-noto-serif text-3xl font-bold text-primary">@Model.ActiveUsers</h4>
         </div>
         <div class="absolute -right-4 -bottom-4 opacity-10 group-hover:opacity-20 transition-opacity duration-500">
             <span class="material-symbols-outlined text-primary" style="font-size:7rem;">task_alt</span>
         </div>
     </div>

     <div class="bg-tertiary text-on-tertiary rounded-xl p-6 shadow-sm flex flex-col justify-between relative overflow-hidden group">
         <div class="relative z-10">
             <p class="font-manrope text-[0.6875rem] uppercase tracking-[0.1em] font-bold opacity-70 mb-2">New Registrations</p>
             <h4 class="font-noto-serif text-3xl font-bold">780</h4>
         </div>
         <div class="absolute -right-4 -bottom-4 opacity-10 group-hover:opacity-20 transition-opacity duration-500">
             <span class="material-symbols-outlined" style="font-size:7rem;">payments</span>
         </div>
     </div>

 </section>

 @if (TempData["Success"] != null)
    {
        <div class="mb-6 px-6 py-4 bg-primary-container text-on-primary-container rounded-lg font-manrope text-sm flex items-center gap-3">
            <span class="material-symbols-outlined text-lg">check_circle</span>@TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="mb-6 px-6 py-4 bg-error-container text-on-error-container rounded-lg font-manrope text-sm flex items-center gap-3">
            <span class="material-symbols-outlined text-lg">error</span>@TempData["Error"]
        </div>
    }

    <form asp-controller="AdminUsers" asp-action="Index" method="get" class="flex gap-3">
            <div class="relative flex-1 max-w-md">
                <input type="text" name="search" value="@Model.Search"
                       placeholder="Search member, email, book or copy…"
                       class="w-full bg-surface-container-highest border-none rounded-full px-6 py-2.5 font-manrope text-sm outline-none focus:ring-2 focus:ring-primary/20 transition-all" />
                <button type="submit" class="absolute right-3 top-1/2 -translate-y-1/2 text-primary">
                    <span class="material-symbols-outlined text-lg">search</span>
                </button>
            </div>
            @if (!string.IsNullOrEmpty(Model.Search))
            {
                <a  href="?search="
                       class="flex items-center gap-1 px-4 py-2 bg-surface-container rounded-full font-manrope text-xs font-semibold text-on-surface-variant hover:bg-surface-container-high transition-colors">
                    <span class="material-symbols-outlined text-sm">close</span>Clear
                </a>
            }
        </form>
        <section class="bg-surface-container-lowest rounded-xl shadow-sm overflow-hidden border border-outline-variant/30 mb-12">
            <div class="p-6 border-b border-surface-container flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                <h3 class="text-xl font-headline font-bold text-primary">Active Directory</h3>
               
            </div>
            <div class="overflow-x-auto">
                <table class="w-full catalog-table">
                    <thead>
                        <tr>
                            <th>User Name</th>
                            <th>Email</th>
                            <th>Phone Number</th>
                            <th class="text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-surface-container">
                        
                    @foreach (var user in Model.Users)
                    {
                        <tr class="hover:bg-surface-container-low transition-colors @(user.IsActive ? "":"opacity-60")">
                            <td>
                                <div class="flex items-center gap-3">
                                    <img alt="User profile" class="w-8 h-8 object-cover rounded-full shadow-sm" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDEXAmFkn-KDN50sxG6EZLudlCYro4sZZc4LAcm-zch2aCuJzzhxYIprsv257CoBnQlfqVdPUVR_MRvvL_s5hpUH1IcDiuSRo8CMDwi465GYJqfLuP0vKeM0SVIaozrvuvIZBOGBcTEK8eNROqDD0JIhEBsJCmX1rwn7VXuTdevvXJA6oZll5pIhgRz-sQzWkgawnpLWKxHFy8ykn3jWA8M0-ojgO0d2x_9JqaqSsDMRvQg1jf0SREQ2BjKO5wzEi6ngEUp4Pw4Egn-" />
                                    <div>
                                        <p class="font-bold text-on-surface">@user.Name</p>
                                        <p class="text-[0.65rem] font-bold text-primary-fixed-dim uppercase tracking-wider">@user.Role</p>
                                    </div>
                                </div>
                            </td>
                            <td class="text-on-surface-variant">@user.Email</td>
                            <td class="text-on-surface-variant">@user.PhoneNumber</td>
                            <td class="text-right">
                                <div class="flex items-center  gap-3">
                                    <a class="text-primary hover:underline text-xs font-bold" asp-controller="AdminUsers" asp-action="Details" asp-route-userId="@user.Id">See Details</a>
                                    @if (user.IsActive)
                                    {
                                      <a asp-controller="AdminUsers" asp-action="DeactiveEmail" asp-route-userId="@user.Id" class="px-3 py-1 bg-error-container text-error text-[0.65rem] font-bold uppercase rounded-full hover:bg-error hover:text-on-error transition-all">Deactivate</a>

                                    }
                                    else
                                    {
                                      <a asp-controller="AdminUsers" asp-action="ConfirmEmail" asp-route-userId="@user.Id" class="px-3 py-1 bg-primary-container text-on-primary-container text-[0.65rem] font-bold uppercase rounded-full hover:bg-primary hover:text-on-primary transition-all">Activate</a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }

                        @* <tr class="hover:bg-surface-container-low transition-colors">
                            <td>
                                <div class="flex items-center gap-3">
                                    <img alt="User profile" class="w-8 h-8 object-cover rounded-full shadow-sm" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBjosTxng7qrWwLrg7hu8hj_EvWctkwzpPWdJ2Ntgfyl5UYolkJjiTvzSmqInmJZXM6T0fDZw0nGmr81W4aLDjsaPZfakPQRKy6s9lbEYH5xvgQ-tXORxgKK6VY2ALhoyGdaeloPG98pW4gQnDOXnMATLmwTXIGKsSCiBhPCm-NNwaqaDOTeWcckiTNns9XAxfYnbSpeAdYIcwFpl0EgEULBcqCRriJB6Shyd0aIjhzk--wfReLrBQhkPO63AB2j0X329uWLV1GcLf-" />
                                    <div>
                                        <p class="font-bold text-on-surface">Miriam Sterling</p>
                                        <p class="text-[0.65rem] font-bold text-secondary-fixed-dim uppercase tracking-wider">Scholar</p>
                                    </div>
                                </div>
                            </td>
                            <td class="text-on-surface-variant">m.sterling@historians.org</td>
                            <td class="text-on-surface-variant">Nov 05, 2023</td>
                            <td class="text-right">
                                <div class="flex items-center justify-end gap-3">
                                    <a class="text-primary hover:underline text-xs font-bold" href="#">See Details</a>
