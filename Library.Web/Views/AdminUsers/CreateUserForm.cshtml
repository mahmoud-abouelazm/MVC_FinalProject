@model CreateUserVM
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["ActiveNav"] = "Users";

    bool isEdit = Model.Id != 0;
}

<main class="md:ml-64 pt-24 pb-12 px-8">

    <div class="max-w-2xl mx-auto form-card p-8">

        <h2 class="text-2xl font-bold mb-6">Add New User</h2>

        <form asp-action="AddNewUser" method="post" class="space-y-5">

            <div>
                <label class="field-label">Full Name</label>
                <input asp-for="FullName" class="field-input" />
                <span asp-validation-for="FullName" class="field-validation-error"></span>
            </div>

            <div>
                <label class="field-label">Email</label>
                <input asp-for="Email" class="field-input" />
                <span asp-validation-for="Email" class="field-validation-error"></span>
            </div>

            <div>
                <label class="field-label">Phone</label>
                <input asp-for="PhoneNumber" class="field-input" />
            </div>

            <div>
                <label class="field-label">Password</label>
                <input asp-for="Password" type="password" class="field-input" />
            </div>

            <div>
                <label class="field-label">Confirm Password</label>
                <input asp-for="ConfirmPassword" type="password" class="field-input" />
            </div>

            <div>
                <label class="field-label">Role</label>
                <select asp-for="RoleId" asp-items="Model.Roles" class="field-input"></select>
            </div>

            <div class="flex gap-3 pt-4">
                <button type="submit" class="btn-primary">Create</button>
                <a asp-action="Index" class="btn-secondary">Cancel</a>
            </div>

        </form>

    </div>

</main>
