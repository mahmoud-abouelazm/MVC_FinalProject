@model UserRowVM
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
     ViewData["ActiveNav"] = "Users";
}



<style>
    .receipt-card {
        background: #fff;
        border: 1px solid rgba(192,201,190,.2);
        border-radius: .75rem;
        box-shadow: 0 12px 48px rgba(26,28,26,.08);
        max-width: 560px;
    }
    .receipt-row {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        padding: .6rem 0;
        border-bottom: 1px dashed rgba(192,201,190,.4);
        font-family: 'Manrope', sans-serif;
        font-size: .875rem;
    }
    .receipt-row:last-child { border-bottom: none; }
    .receipt-label { color: #404941; font-size: .8rem; }
    .receipt-value { font-weight: 700; color: #1a1c1a; }
    .receipt-total-row {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        padding: 1rem 0 0;
        margin-top: .5rem;
        border-top: 2px solid #1a1c1a;
    }
    .btn-confirm {
        width: 100%;
        background: #00321a; color: #fff; border: none;
        border-radius: .375rem; padding: 1.1rem;
        font-family: 'Manrope', sans-serif; font-size: .8rem;
        font-weight: 700; letter-spacing: .15em; text-transform: uppercase;
        cursor: pointer; transition: background .2s;
        display: flex; align-items: center; justify-content: center; gap: .5rem;
    }
    .btn-confirm:hover { background: #004b2a; }
    .btn-cancel {
        width: 100%; background: transparent;
        border: 1px solid rgba(192,201,190,.5);
        border-radius: .375rem; padding: 1rem;
        font-family: 'Manrope', sans-serif; font-size: .8rem;
        font-weight: 700; letter-spacing: .15em; text-transform: uppercase;
        color: #404941; text-decoration: none;
        display: flex; align-items: center; justify-content: center; gap: .5rem;
        transition: background .2s;
    }
    .btn-cancel:hover { background: #f3f4f0; }
    .penalty-block {
        background: rgba(186,26,26,.06);
        border: 1px solid rgba(186,26,26,.2);
        border-radius: .375rem;
        padding: .875rem 1rem;
    }
</style>

<main class="ml-64 min-h-screen p-12">

    <header class="mb-10">
        <a asp-controller="AdminUsers" asp-action="Index"
           class="inline-flex items-center gap-1 font-manrope text-xs text-on-surface-variant hover:text-primary transition-colors mb-4 uppercase tracking-wider font-semibold">
            <span class="material-symbols-outlined text-base">arrow_back</span>
            Back to Users
        </a>
      
    </header>

    <div class="receipt-card">

        <div class="bg-tertiary text-on-tertiary px-8 py-6 rounded-t-xl">
            <div class="flex justify-between items-start">
                <div>
                    <h3 class="font-noto-serif text-2xl font-bold">@Model.Name</h3>
                    <p class="font-manrope text-xs opacity-70 mt-0.5">@Model.Role</p>
                </div>
                <div class="text-right">
                    <span class="material-symbols-outlined" style="font-size:2.5rem; opacity:.4;">receipt_long</span>
                </div>
            </div>
        </div>

        <div class="px-8 py-6 space-y-6">

            <div>
                <p class="font-manrope text-[0.6875rem] uppercase tracking-[0.1em] font-bold text-on-surface-variant mb-3">User Details</p>
                <div class="receipt-row">
                    <span class="receipt-label">Phone Number</span>
                    <span class="receipt-value text-right max-w-xs text-sm">@Model.PhoneNumber</span>
                </div>
                <div class="receipt-row">
                    <span class="receipt-label">Email</span>
                    <span class="receipt-value text-sm">@Model.Email</span>
                </div>
              
                <div class="receipt-row" style="border-bottom:none;">
                    <span class="receipt-label">Is Active</span>
                    <span class="receipt-value">@(Model.IsActive ? "Yes ✅" : "No ❌")</span>
                </div>
            </div>

                <a asp-controller="AdminUsers" asp-action="Index" class="btn-cancel">
                    <span class="material-symbols-outlined text-base">close</span>
                    Cancel
                </a>

        </div>
    </div>

</main>
