@using Library.Web.Core.Constants
@using Library.Web.Core.ViewModel.Book
@using Library.Web.Core.ViewModel.Category


 @model PagedResult<BookRowVM>

@{
    int totalPages = (int)Math.Ceiling((double)Model.TotalCount / 8);
    
    List<CategoryRowVM>? categories = ViewBag.Categories;
    var selectedCategory = ViewBag.SelectedCategory as int?;

    var selectedName = categories
        ?.FirstOrDefault(c => c.Id == selectedCategory)?.Name ?? "All Categories";
}



<main class="flex-grow pt-16 pb-12 px-4 sm:px-6 max-w-[2200px] mx-auto w-full">
    <!-- Page Header -->
    <header class="mb-12">
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-6">

            <div>
                <p class="font-manrope text-[0.6875rem] uppercase tracking-[0.05em] text-secondary font-bold mb-2">
                    
                </p>
                <h1 class="text-4xl md:text-5xl font-noto-serif text-primary">Public Catalog </h1>
            </div>

            <!-- Categories Dropdown/Filter -->

            <div class="flex gap-4">
                <div class="relative group">
    
                    <form method="get" asp-action="Index">
    
                        <select name="categoryId"
                                class="px-6 py-3 bg-surface-container-low hover:bg-surface-container-high rounded-xl text-sm font-semibold"
                                onchange="this.form.submit()">

                            <!-- All Categories -->
                            <option value="">
                                All Categories
                            </option>

                            @foreach (var cat in categories)
                            {
                                <option value="@cat.Id"
                                        selected="@(selectedCategory == cat.Id)">
                
                                    @cat.Name (@cat.BookCount)
                                </option>
                            }

                        </select>

                    </form>

                </div>
            </div>

            @* ///////////////////////////////////////////////////////////////// Filter *@

        </div>
    </header>

    <!-- Catalog Grid (Asymmetric feel with specific spacing) -->
    <section class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-x-8 gap-y-16">


        @foreach(var Book in Model.Data)
        {
            <!-- Book Card 1 -->
            <article class="flex flex-col group">

                <div class="aspect-[3/4] overflow-hidden rounded-xl bg-surface-container-low transition-all duration-300 group-hover:shadow-[0px_12px_32px_rgba(26,28,26,0.12)]">
                    
                    <img alt="@Book.Title"
                         class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                         data-alt="@Book.CategoryName"
                         src="/@Book.Img" />
                </div>
                <div class="mt-6">

                    <div class="flex justify-between items-start mb-2">
                        <h3 class="text-xl font-noto-serif text-on-surface leading-tight">@Book.Title</h3>
                        <span class="font-manrope font-bold text-primary-container">$@Book.Price</span>
                    </div>

                    <p class="text-sm font-manrope text-on-surface-variant mb-4">@Book.AuthorNames</p>
                   
                    <a asp-controller="Books" asp-action="Details" asp-route-id="@Book.Id"
                           class="inline-flex items-center gap-2 text-sm font-bold text-primary hover:text-white transition-all group">
                        View Details
                        <span class="material-symbols-outlined text-xl transition-transform duration-300 group-hover:translate-x-1">
                            arrow_forward
                        </span>
                    </a>

                </div>
            </article>


        }


   

    </section>



    <!-- Pagination -->
    <nav class="mt-24 flex justify-center items-center gap-2">

        <button class="w-10 h-10 flex items-center justify-center rounded-lg hover:bg-surface-container-low transition-colors text-on-surface/50">
            <span class="material-symbols-outlined">chevron_left</span>
        </button>


        @for (int i = 1; i < totalPages; i++)
        {
               <a class="w-10 h-10 flex items-center justify-center rounded-lg hover:bg-surface-container-low transition-colors font-semibold"
               asp-action="Index" asp-route-page="@i" asp-route-categoryId="@selectedCategory">
               
               @i</a>
        }

        <span class="px-2 text-on-surface/30">...</span>
        
        <a class="w-10 h-10 flex items-center justify-center rounded-lg hover:bg-surface-container-low transition-colors font-semibold"
               asp-action="Index" asp-route-page="@totalPages" asp-route-categoryId="@selectedCategory">
            @totalPages
       </a>

        <button class="w-10 h-10 flex items-center justify-center rounded-lg hover:bg-surface-container-low transition-colors text-primary">
            <span class="material-symbols-outlined">chevron_right</span>
        </button>

    </nav>

</main>































        
