@using Library.Web.Core.ViewModel.BookVMs
@model BookDetailsVM

<style>
    .date-input-themed::-webkit-calendar-picker-indicator {
        opacity: 0;
        position: absolute;
        right: 0;
        top: 0;
        width: 2rem;
        height: 100%;
        cursor: pointer;
    }

    .date-input-themed {
        position: relative;
    }

    .flatpickr-calendar {
        background: #f9faf6;
        border: 1px solid #c0c9be;
        border-radius: 0.75rem;
        box-shadow: 0 10px 30px rgba(26, 28, 26, 0.12);
    }

    .flatpickr-day.selected,
    .flatpickr-day.startRange,
    .flatpickr-day.endRange,
    .flatpickr-day.selected:hover,
    .flatpickr-day.startRange:hover,
    .flatpickr-day.endRange:hover {
        background: #004b2a;
        border-color: #004b2a;
    }

    .flatpickr-day.today {
        border-color: #046d3f;
    }

    .flatpickr-day:hover {
        background: #e7e9e5;
    }

    .flatpickr-current-month,
    .flatpickr-weekday,
    .flatpickr-monthDropdown-months,
    .numInputWrapper {
        color: #1a1c1a;
    }
</style>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">

<main class="pt-32 pb-20 px-6 md:px-12 max-w-7xl mx-auto" style="padding-top:40px">
    <!-- Back Action -->
    <div class="mb-10 flex items-center">
        <a asp-action="index" asp-controller="books" class="group flex items-center gap-2 text-on-surface-variant hover:text-primary transition-colors" >
            <span class="material-symbols-outlined text-sm">arrow_back</span>
            <span class="font-label text-xs font-bold uppercase tracking-widest">Return to Collection</span>
        </a>
    </div>
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-start">
        <!-- Book Cover Section (Asymmetric Column) -->
        <div class="lg:col-span-5 relative">
            <div class="aspect-[3/4] rounded-lg overflow-hidden shadow-2xl bg-surface-container-low group">
                <img class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" alt="Cover of @Model.Title" src="/@Model.Img">
                <!-- Floating Metadata Tag -->
                <div class="absolute top-6 left-6">
                    <span class="bg-primary px-4 py-1.5 rounded-full text-on-primary font-label text-[0.625rem] font-bold uppercase tracking-widest shadow-lg">
                        Archival Grade A
                    </span>
                </div>
            </div>
            <!-- Ambient Glow Behind Cover -->
            <div class="absolute -z-10 inset-0 blur-[100px] opacity-20 bg-primary-container rounded-full scale-75 translate-y-12"></div>
        </div>
        <!-- Book Information Section -->
        <div class="lg:col-span-7 flex flex-col gap-10">
            <!-- Title & Header -->
            <header class="space-y-4">
                
                <h1 class="font-headline text-5xl md:text-6xl text-on-surface leading-tight font-bold">@Model.Title</h1>
            </header>
            <!-- Status Bento Grid Row -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="bg-surface-container-low p-6 rounded-xl flex flex-col gap-1 border-b-2 border-primary-fixed">
                    <span class="font-label text-[0.625rem] font-bold uppercase tracking-widest text-on-surface-variant">Availability</span>
                    <div class="flex items-baseline gap-1">
                        <span class="text-3xl font-headline text-primary font-bold">@Model.copiesNumber</span>
                        <span class="text-xs font-body text-on-surface-variant">copies left</span>
                    </div>
                </div>
                <div class="bg-surface-container-low p-6 rounded-xl flex flex-col gap-1">
                    <span class="font-label text-[0.625rem] font-bold uppercase tracking-widest text-on-surface-variant">Rental Price</span>
                    <span class="text-lg font-body font-bold text-on-surface">@Model.Price $</span>
                </div>
                
            </div>
            <!-- Main Synopsis -->
            <div class="space-y-4">
                <h3 class="font-headline text-2xl font-bold border-l-4 border-primary pl-4">Description</h3>
                <p class="font-body text-on-surface-variant leading-relaxed text-lg">
                    @Model.Description
                </p>
            </div>
            <!-- Author Bio Section -->
            @foreach(var author in Model.Authors)
            {
                
            <div class="bg-surface-container-lowest p-8 rounded-xl flex flex-col md:flex-row gap-8 items-center md:items-start shadow-sm border border-outline-variant/15">
                <div class="w-24 h-24 rounded-full overflow-hidden shrink-0">
                </div>
                <div class="space-y-3">
                    <div class="flex flex-col">
                        <span class="font-label text-[0.625rem] font-bold uppercase tracking-widest text-primary">About the Author</span>
                        <h4 class="font-headline text-xl font-bold">@author.Name</h4>
                    </div>
                    <p class="font-body text-sm text-on-surface-variant leading-relaxed">
                        @author.Bio
                    </p>
                </div>
            </div>
            }
            <!-- CTA Action Row -->
            @{
                var maxCopies = Math.Min(5, Model.copiesNumber);
                var isUnavailable = Model.copiesNumber <= 0;
                var minReturnDate = DateTime.Today.ToString("yyyy-MM-dd");
                var maxReturnDate = DateTime.Today.AddMonths(1).ToString("yyyy-MM-dd");
            }
            <form asp-action="rentBook" asp-controller="books" method="post" class="mt-4">
                <input type="hidden" name="Id" value="@Model.Id" />
                <div class="w-full sm:w-auto bg-surface-container-low rounded-xl p-2 border border-outline-variant/20 shadow-xl">
                    <div class="flex flex-col sm:flex-row items-stretch gap-2">
                        <div class="bg-surface-container rounded-lg px-4 py-2 border border-outline-variant/20 flex flex-col justify-center min-w-[220px]">
                            <label for="returnDate" class="font-label text-[0.625rem] font-bold uppercase tracking-widest text-on-surface-variant">Return Date</label>
                            <div class="relative mt-1">
                                <input id="returnDate"
                                       name="returnDate"
                                       type="text"
                                       min="@minReturnDate"
                                       max="@maxReturnDate"
                                       value="@minReturnDate"
                                       class="date-input-themed w-full bg-transparent text-on-surface font-body font-semibold border-none focus:ring-0 p-0 pr-8"
                                       required
                                       disabled="@isUnavailable" />
                                <button type="button"
                                        id="openDatePicker-@Model.Id"
                                        class="absolute right-0 top-1/2 -translate-y-1/2 text-on-surface-variant hover:text-primary transition-colors"
                                        aria-label="Open return date picker"
                                        disabled="@isUnavailable">
                                    <span class="material-symbols-outlined text-[20px]">calendar_month</span>
                                </button>
                            </div>
                        </div>
                        <div class="relative min-w-[110px]" id="copiesDropdown-@Model.Id">
                            <input type="hidden" name="copiesNumber" value="@(maxCopies > 0 ? 1 : 0)" id="copiesValue-@Model.Id" />
                            <button type="button"
                                    id="copiesTrigger-@Model.Id"
                                    class="w-full bg-primary text-on-primary rounded-lg pl-4 pr-10 py-4 font-body font-bold text-lg border border-white/10 flex items-center justify-between @(!isUnavailable ? "cursor-pointer" : "cursor-not-allowed opacity-60")"
                                    disabled="@isUnavailable"
                                    aria-haspopup="listbox"
                                    aria-expanded="false">
                                <span id="copiesText-@Model.Id">@(maxCopies > 0 ? "1" : "0")</span>
                                <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none text-on-primary">expand_more</span>
                            </button>

                            <div id="copiesMenu-@Model.Id" class="hidden absolute left-0 right-0 top-[calc(100%+4px)] z-30 bg-surface-container-highest border border-outline-variant/40 rounded-lg shadow-xl overflow-hidden">
                                <ul class="max-h-56 overflow-y-auto" role="listbox" aria-label="Select number of copies">
                                    @for (var i = 1; i <= maxCopies; i++)
                                    {
                                        <li>
                                            <button type="button"
                                                    class="w-full text-left px-4 py-2.5 font-body text-on-surface hover:bg-surface-container-high transition-colors copy-option-@Model.Id"
                                                    data-value="@i">
                                                @i
                                            </button>
                                        </li>
                                    }
                                </ul>
                            </div>
                        </div>
                        <button type="submit"
                                class="flex-1 sm:w-auto bg-primary text-on-primary px-8 py-4 font-body font-bold text-lg rounded-lg transition-all duration-300 flex items-center justify-center gap-3 @(!isUnavailable ? "hover:bg-primary-container active:scale-95" : "opacity-60 cursor-not-allowed")"
                                disabled="@isUnavailable">
                            <span>@(isUnavailable ? "Not Available" : "Rent Now")</span>
                            <span class="material-symbols-outlined">auto_stories</span>
                        </button>
                    </div>
                </div>
            <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
            <script>
                (function () {
                    const dropdown = document.getElementById('copiesDropdown-@Model.Id');
                    const trigger = document.getElementById('copiesTrigger-@Model.Id');
                    const menu = document.getElementById('copiesMenu-@Model.Id');
                    const valueInput = document.getElementById('copiesValue-@Model.Id');
                    const text = document.getElementById('copiesText-@Model.Id');
                    const returnDateInput = document.getElementById('returnDate');
                    const openDatePickerButton = document.getElementById('openDatePicker-@Model.Id');
                    let datePickerInstance = null;

                    if (returnDateInput && typeof flatpickr === 'function') {
                        datePickerInstance = flatpickr(returnDateInput, {
                            dateFormat: 'Y-m-d',
                            defaultDate: returnDateInput.value,
                            minDate: returnDateInput.getAttribute('min'),
                            maxDate: returnDateInput.getAttribute('max'),
                            disableMobile: true,
                            allowInput: false
                        });
                    }

                    if (returnDateInput && openDatePickerButton && !returnDateInput.disabled) {
                        openDatePickerButton.addEventListener('click', function (e) {
                            e.preventDefault();

                            if (datePickerInstance) {
                                datePickerInstance.open();
                                return;
                            }

                            returnDateInput.focus();
                            returnDateInput.click();
                        });
                    }

                    if (!dropdown || !trigger || !menu || !valueInput || !text || trigger.disabled) return;

                    const options = dropdown.querySelectorAll('.copy-option-@Model.Id');

                    const closeMenu = function () {
                        menu.classList.add('hidden');
                        trigger.setAttribute('aria-expanded', 'false');
                    };

                    const openMenu = function () {
                        menu.classList.remove('hidden');
                        trigger.setAttribute('aria-expanded', 'true');
                    };

                    trigger.addEventListener('click', function () {
                        if (menu.classList.contains('hidden')) {
                            openMenu();
                            return;
                        }

                        closeMenu();
                    });

                    options.forEach(function (option) {
                        option.addEventListener('click', function () {
                            const selected = option.getAttribute('data-value');
                            if (!selected) return;

                            valueInput.value = selected;
                            text.textContent = selected;
                            closeMenu();
                        });
                    });

                    document.addEventListener('click', function (event) {
                        if (!dropdown.contains(event.target)) {
                            closeMenu();
                        }
                    });

                    document.addEventListener('keydown', function (event) {
                        if (event.key === 'Escape') {
                            closeMenu();
                        }
                    });
                })();
            </script>
            </form>
        </div>
    </div>
</main>