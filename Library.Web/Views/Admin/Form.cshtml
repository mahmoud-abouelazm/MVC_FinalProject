<main class="ml-64 min-h-screen p-12">

    <header class="mb-10">
        <a asp-controller="Admin" asp-action="Index"
           class="inline-flex items-center gap-1 font-manrope text-xs text-on-surface-variant hover:text-primary transition-colors mb-4 uppercase tracking-wider font-semibold">
            <span class="material-symbols-outlined text-base">arrow_back</span>
            Back to Books
        </a>
        <h2 class="font-noto-serif text-4xl font-bold text-on-surface tracking-tight">
            @(isEdit ? "Edit Book" : "Add New Book")
        </h2>
        <p class="text-on-surface-variant mt-2 font-manrope text-sm">
            @(isEdit ? "Update the details of this archival title." : "Register a new title in the archive.")
        </p>
    </header>

    <div class="max-w-3xl">
        <form asp-controller="Admin" asp-action="@(isEdit ? "Edit" : "Create")" method="post"
              enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="Img" id="currentImg" />

            <div class="form-card p-8 space-y-7">

                <div class="grid grid-cols-2 gap-6">
                    <div class="col-span-2">
                        <label class="field-label" for="Title">Book Title</label>
                        <input class="field-input" id="Title" asp-for="Title"
                               placeholder="e.g. The Glass Monographs" />
                        <span class="field-validation-error" asp-validation-for="Title"></span>
                    </div>

                    <div>
                        <label class="field-label" for="CategoryId">Category</label>
                        <select class="field-input" id="CategoryId" asp-for="CategoryId"
                                asp-items="Model.Categories">
                            <option value="">— Select —</option>
                        </select>
                        <span class="field-validation-error" asp-validation-for="CategoryId"></span>
                    </div>

                    <div>
                        <label class="field-label" for="Price">Price ($)</label>
                        <input class="field-input" id="Price" asp-for="Price"
                               type="number" step="0.01" min="0" placeholder="0.00" />
                        <span class="field-validation-error" asp-validation-for="Price"></span>
                    </div>
                </div>

                <div>
                    <label class="field-label">Authors</label>
                    <div class="checkbox-grid">
                        @foreach (var author in Model.Authors)
                        {
                            <label class="checkbox-item">
                                <input type="checkbox"
                                       name="AuthorIds"
                                       value="@author.Value"
                                       @(Model.AuthorIds.Contains(int.Parse(author.Value)) ? "checked" : "") />
                                @author.Text
                            </label>
                        }
                    </div>
                    <span class="field-validation-error" asp-validation-for="AuthorIds"></span>
                </div>

                <div>
                    <label class="field-label" for="Description">Description</label>
                    <textarea class="field-input" id="Description" asp-for="Description"
                              placeholder="Brief summary for the digital collection..." rows="4"></textarea>
                </div>

                <div>
                    <label class="field-label">Cover Image</label>
                    <div class="flex items-start gap-6">
                        @if (!string.IsNullOrEmpty(Model.Img))
                        {
                            <img src="@Model.Img" alt="Current cover" class="img-preview" />
                        }
                        <div class="flex-1">
                            <input type="file" name="CoverImage" id="CoverImage"
                                   accept="image/jpeg,image/png"
                                   class="field-input" style="padding:.5rem;" />
                            @if (!string.IsNullOrEmpty(Model.Img))
                            {
                                <p class="font-manrope text-xs text-on-surface-variant mt-2">
                                    Leave empty to keep the current cover image.
                                </p>
                            }
                        </div>
                    </div>
                </div>

            </div>

            <div class="flex items-center gap-4 mt-6">
                <button type="submit" class="btn-primary">
                    @(isEdit ? "Save Changes" : "Add to Archive")
                </button>
                <a asp-controller="Admin" asp-action="Index" class="btn-secondary">Cancel</a>
            </div>

        </form>
    </div>
</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
